    funcao inicializar_jogo()
    {
        limpa()
        escreva(NOME_JOGO, "\n")
        escreva(VERSAO, "\n\n")
        Util.aguarde(1000)

        // Inicializar habilidades das classes
        inicializar_habilidades()

        // Inicializar loja
        inicializar_loja()

        // Inicializar eventos
        inicializar_eventos()

        // Inicializar quests iniciais
        inicializar_quests()
    }

