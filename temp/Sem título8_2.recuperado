    // ==========================================
    // SISTEMA DE CALCULOS
    // ==========================================
    funcao inteiro calcular_hp_max()
    {
        inteiro base = 100 + (g_vitalidade * 15) + (g_equip_vitalidade * 15)
        inteiro bonus_nivel = g_nivel * 12
        retorne base + bonus_nivel
    }

    funcao inteiro calcular_mana_max()
    {
        inteiro base = 50 + (g_inteligencia * 8) + (g_equip_inteligencia * 8)
        inteiro bonus_nivel = g_nivel * 10
        retorne base + bonus_nivel
    }

    funcao inteiro calcular_ataque_total()
    {
        inteiro base = g_arma_dano + (g_forca * 1.8) + (g_equip_forca * 1.8)
        inteiro bonus_nivel = g_nivel * 8
        inteiro refino_bonus = 0
        se (g_arma_nivel_refino == 1) { refino_bonus = 10 }
        senao se (g_arma_nivel_refino == 2) { refino_bonus = 25 }
        senao se (g_arma_nivel_refino == 3) { refino_bonus = 40 }
        senao se (g_arma_nivel_refino == 4) { refino_bonus = 60 }
        senao se (g_arma_nivel_refino == 5) { refino_bonus = 100 }
        inteiro total = base + bonus_nivel + (base * refino_bonus / 100)
        retorne total
    }

    funcao inteiro calcular_defesa_total()
    {
        inteiro base = g_defesa + g_armadura_defesa + g_equip_defesa
        inteiro bonus_nivel = g_nivel * 7
        retorne base + bonus_nivel
    }

    funcao inteiro calcular_reducao_dano(inteiro defesa)
    {
        real reducao = defesa * 0.35
        se (reducao > LIMITE_REDUCAO_DANO) { reducao = LIMITE_REDUCAO_DANO }
        retorne Matematica.arredondar(reducao, 0)
    }

    funcao inteiro calcular_critico_total()
    {
        inteiro total = g_critico + g_equip_critico
        se (total > LIMITE_CRITICO) { total = LIMITE_CRITICO }
        retorne total
    }

    funcao inteiro calcular_esquiva_total()
    {
        inteiro total = g_esquiva + g_equip_esquiva
        se (total > LIMITE_ESQUIVA) { total = LIMITE_ESQUIVA }
        retorne total
    }

    funcao real calcular_peso_max()
    {
        retorne PESO_BASE + (g_forca * 1.5)
    }

    funcao inteiro calcular_xp_proximo()
    {
        real xp = 100.0
        inteiro nivel_float = g_nivel
        inteiro i
        para (i = 0; i < nivel_float; i = i + 1)
        {
            xp = xp * 1.45
        }
        retorne Matematica.arredondar(xp, 0)
    }

    // ==========================================
    // SISTEMA ELEMENTAL
    // ==========================================
    funcao real verificar_fracao_elemental(inteiro atacante_elem, inteiro defensor_elem)
    {
        real multiplicador = 1.0
        se (atacante_elem == ELEM_FOGO e defensor_elem == ELEM_GELO) { multiplicador = 2.0 }
        senao se (atacante_elem == ELEM_GELO e defensor_elem == ELEM_TERRA) { multiplicador = 2.0 }
        senao se (atacante_elem == ELEM_TERRA e defensor_elem == ELEM_FOGO) { multiplicador = 2.0 }
        senao se (atacante_elem == ELEM_LUZ e defensor_elem == ELEM_TREVAS) { multiplicador = 2.0 }
        senao se (atacante_elem == ELEM_TREVAS e defensor_elem == ELEM_LUZ) { multiplicador = 2.0 }
        senao se (defensor_elem == ELEM_FOGO e atacante_elem == ELEM_GELO) { multiplicador = 0.5 }
        senao se (defensor_elem == ELEM_GELO e atacante_elem == ELEM_TERRA) { multiplicador = 0.5 }
        senao se (defensor_elem == ELEM_TERRA e atacante_elem == ELEM_FOGO) { multiplicador = 0.5 }
        senao se (defensor_elem == ELEM_LUZ e atacante_elem == ELEM_TREVAS) { multiplicador = 0.5 }
        senao se (defensor_elem == ELEM_TREVAS e atacante_elem == ELEM_LUZ) { multiplicador = 0.5 }
        retorne multiplicador
    }

    funcao cadeia nome_elemento(inteiro elem)
    {
        se (elem == ELEM_FOGO) { retorne "Fogo" }
        senao se (elem == ELEM_GELO) { retorne "Gelo" }
        senao se (elem == ELEM_TERRA) { retorne "Terra" }
        senao se (elem == ELEM_LUZ) { retorne "Luz" }
        senao se (elem == ELEM_TREVAS) { retorne "Trevas" }
        senao se (elem == ELEM_RAIO) { retorne "Raio" }
        retorne "Neutro"
    }

    funcao cadeia nome_classe(inteiro cls)
    {
        se (cls == CLS_GUERREIRO) { retorne "Guerreiro" }
        senao se (cls == CLS_MAGO) { retorne "Mago" }
        senao se (cls == CLS_LADINO) { retorne "Ladino" }
        senao se (cls == CLS_PALADINO) { retorne "Paladino" }
        senao se (cls == CLS_ARQUEIRO) { retorne "Arqueiro" }
        senao se (cls == CLS_DRUIDA) { retorne "Druida" }
        senao se (cls == CLS_NECROMANTE) { retorne "Necromante" }
        senao se (cls == CLS_MONGE) { retorne "Monge" }
        retorne "Desconhecido"
    }

    funcao cadeia nome_raridade(inteiro rar)
    {
        se (rar == RAR_COMUM) { retorne "Comum" }
        senao se (rar == RAR_INCOMUM) { retorne "Incomum" }
        senao se (rar == RAR_RARO) { retorne "Raro" }
        senao se (rar == RAR_EPICO) { retorne "Epico" }
        senao se (rar == RAR_LENDARIO) { retorne "Lendario" }
        senao se (rar == RAR_MITICO) { retorne "Mitico" }
        retorne "Comum"
    }

    // ==========================================
    // SISTEMA DE BUFFS/DEBUFFS
    // ==========================================
    funcao aplicar_buff(cadeia nome, inteiro duracao, inteiro intensidade, inteiro tipo)
    {
        inteiro i
        // Verificar se buff ja existe (renovar)
        para (i = 0; i < g_buff_count; i = i + 1)
        {
            se (g_buff_ativo[i] e g_buff_nome[i] == nome)
            {
                g_buff_duracao[i] = duracao
                g_buff_intensidade[i] = intensidade
                retorne
            }
        }
        // Adicionar novo buff
        se (g_buff_count < MAX_BUFFS)
        {
            g_buff_nome[g_buff_count] = nome
            g_buff_duracao[g_buff_count] = duracao
            g_buff_intensidade[g_buff_count] = intensidade
            g_buff_tipo[g_buff_count] = tipo
            g_buff_ativo[g_buff_count] = verdadeiro
            g_buff_count = g_buff_count + 1
        }
    }

    funcao aplicar_debuff(cadeia nome, inteiro duracao, inteiro intensidade, inteiro tipo)
    {
        inteiro i
        inteiro max_debuffs = MAX_DEBUFFS * 3
        // Verificar se debuff ja existe
        para (i = 0; i < g_debuff_count; i = i + 1)
        {
            se (g_debuff_ativo[i] e g_debuff_nome[i] == nome)
            {
                g_debuff_duracao[i] = duracao
                retorne
            }
        }
        // Adicionar novo debuff
        se (g_debuff_count < max_debuffs)
        {
            g_debuff_nome[g_debuff_count] = nome
            g_debuff_duracao[g_debuff_count] = duracao
            g_debuff_intensidade[g_debuff_count] = intensidade
            g_debuff_tipo[g_debuff_count] = tipo
            g_debuff_ativo[g_debuff_count] = verdadeiro
            g_debuff_count = g_debuff_count + 1
        }
    }

    funcao atualizar_efeitos_jogador()
    {
        inteiro i
        // Atualizar buffs
        para (i = 0; i < g_buff_count; i = i + 1)
        {
            se (g_buff_ativo[i])
            {
                g_buff_duracao[i] = g_buff_duracao[i] - 1
                se (g_buff_duracao[i] <= 0)
                {
                    g_buff_ativo[i] = falso
                    escreva("[Efeito Encerrado] ", g_buff_nome[i], " terminoUtil.\n")
                }
            }
        }
        // Atualizar debuffs
        para (i = 0; i < g_debuff_count; i = i + 1)
        {
            se (g_debuff_ativo[i])
            {
                g_debuff_duracao[i] = g_debuff_duracao[i] - 1
                se (g_debuff_duracao[i] <= 0)
                {
                    g_debuff_ativo[i] = falso
                    escreva("[Efeito Encerrado] ", g_debuff_nome[i], " terminoUtil.\n")
                }
            }
        }
    }

    funcao processar_efeitos_turno_jogador()
    {
        inteiro i
        para (i = 0; i < g_buff_count; i = i + 1)
        {
            se (g_buff_ativo[i])
            {
                // Tipo 1 = Regeneracao HP
                se (g_buff_tipo[i] == 1)
                {
                    inteiro cura = g_buff_intensidade[i]
                    se (g_hp_atual + cura > g_hp_max) { cura = g_hp_max - g_hp_atual }
                    g_hp_atual = g_hp_atual + cura
                    escreva("[Regeneracao] Voce recuperou ", cura, " HP.\n")
                }
                // Tipo 2 = Regeneracao Mana
                se (g_buff_tipo[i] == 2)
                {
                    inteiro mana_rec = g_buff_intensidade[i]
                    se (g_mana_atual + mana_rec > g_mana_max) { mana_rec = g_mana_max - g_mana_atual }
                    g_mana_atual = g_mana_atual + mana_rec
                }
            }
        }
        // Processar debuffs
        para (i = 0; i < g_debuff_count; i = i + 1)
        {
            se (g_debuff_ativo[i])
            {
                // Tipo 1 = Veneno
                se (g_debuff_tipo[i] == 1)
                {
                    dano = g_debuff_intensidade[i]
                    g_hp_atual = g_hp_atual - dano
                    escreva("[Veneno] Voce perdeu ", dano, " HP.\n")
                }
                // Tipo 2 = Queimadura
                se (g_debuff_tipo[i] == 2)
                {
                    dano = g_debuff_intensidade[i]
                    g_hp_atual = g_hp_atual - dano
                    escreva("[Queimadura] Voce perdeu ", dano, " HP.\n")
                }
                // Tipo 3 = Sangramento
                se (g_debuff_tipo[i] == 3)
                {
                    dano = g_debuff_intensidade[i]
                    g_hp_atual = g_hp_atual - dano
                    escreva("[Sangramento] Voce perdeu ", dano, " HP.\n")
                }
            }
        }
    }

    funcao logico possui_buff(inteiro tipo)
    {
        inteiro i
        para (i = 0; i < g_buff_count; i = i + 1)
        {
            se (g_buff_ativo[i] e g_buff_tipo[i] == tipo) { retorne verdadeiro }
        }
        retorne falso
    }

    funcao logico possui_debuff(inteiro tipo)
    {
        inteiro i
        para (i = 0; i < g_debuff_count; i = i + 1)
        {
            se (g_debuff_ativo[i] e g_debuff_tipo[i] == tipo) { retorne verdadeiro }
        }
        retorne falso
    }

    // ==========================================
    // SISTEMA DE INVENTARIO
    // ==========================================
    funcao logico adicionar_item(cadeia nome, cadeia desc, cadeia categoria, inteiro raridade, inteiro tipo, inteiro elemento, inteiro quantidade, real peso, inteiro valor, inteiro nivel_req, logico empilhavel, logico utilizavel, logico equipavel, logico descartavel, logico quest, inteiro bonus_forca, inteiro bonus_defesa, inteiro bonus_critico, inteiro bonus_agi, inteiro bonus_mana, inteiro bonus_hp, inteiro efeito_principal)
    {
        // Verificar se pode empilhar
        inteiro i
        se (empilhavel e quantidade > 1)
        {
            para (i = 0; i < g_inv_slots_usados; i = i + 1)
            {
                se (g_inv_nome[i] == nome e g_inv_quantidade[i] < g_inv_qtd_max[i])
                {
                    inteiro espaco = g_inv_qtd_max[i] - g_inv_quantidade[i]
                    se (quantidade <= espaco)
                    {
                        g_inv_quantidade[i] = g_inv_quantidade[i] + quantidade
                        retorne verdadeiro
                    }
                    senao
                    {
                        g_inv_quantidade[i] = g_inv_qtd_max[i]
                        quantidade = quantidade - espaco
                    }
                }
            }
        }
        // Verificar slots
        se (g_inv_slots_usados >= MAX_SLOTS)
        {
            escreva("[Inventario Cheio] Nao ha espaco disponivel.\n")
            retorne falso
        }
        // Verificar peso
        se (g_peso_atual + peso > calcular_peso_max())
        {
            escreva("[Peso Excessivo] Inventario muito pesado.\n")
            retorne falso
        }
        // Adicionar novo item
        g_inv_nome[g_inv_slots_usados] = nome
        g_inv_desc[g_inv_slots_usados] = desc
        g_inv_categoria[g_inv_slots_usados] = categoria
        g_inv_raridade[g_inv_slots_usados] = raridade
        g_inv_tipo[g_inv_slots_usados] = tipo
        g_inv_elemento[g_inv_slots_usados] = elemento
        g_inv_quantidade[g_inv_slots_usados] = quantidade
        g_inv_qtd_max[g_inv_slots_usados] = 10
        g_inv_peso[g_inv_slots_usados] = peso
        g_inv_valor[g_inv_slots_usados] = valor
        g_inv_nivel_req[g_inv_slots_usados] = nivel_req
        g_inv_empilhavel[g_inv_slots_usados] = empilhavel
        g_inv_utilizavel[g_inv_slots_usados] = utilizavel
        g_inv_equipavel[g_inv_slots_usados] = equipavel
        g_inv_descartavel[g_inv_slots_usados] = descartavel
        g_inv_quest[g_inv_slots_usados] = quest
        g_inv_bonus_forca[g_inv_slots_usados] = bonus_forca
        g_inv_bonus_defesa[g_inv_slots_usados] = bonus_defesa
        g_inv_bonus_critico[g_inv_slots_usados] = bonus_critico
        g_inv_bonus_agi[g_inv_slots_usados] = bonus_agi
        g_inv_bonus_mana[g_inv_slots_usados] = bonus_mana
        g_inv_bonus_hp[g_inv_slots_usados] = bonus_hp
        g_inv_efeito_principal[g_inv_slots_usados] = efeito_principal
        g_inv_durabilidade[g_inv_slots_usados] = 100
        g_inv_durabilidade_max[g_inv_slots_usados] = 100
        g_peso_atual = g_peso_atual + peso
        g_inv_slots_usados = g_inv_slots_usados + 1
        retorne verdadeiro
    }

    funcao remover_item(inteiro idx)
    {
        se (idx >= 0 e idx < g_inv_slots_usados)
        {
            g_peso_atual = g_peso_atual - g_inv_peso[idx]
            inteiro i
            para (i = idx; i < g_inv_slots_usados - 1; i = i + 1)
            {
                g_inv_nome[i] = g_inv_nome[i + 1]
                g_inv_desc[i] = g_inv_desc[i + 1]
                g_inv_categoria[i] = g_inv_categoria[i + 1]
                g_inv_raridade[i] = g_inv_raridade[i + 1]
                g_inv_tipo[i] = g_inv_tipo[i + 1]
                g_inv_elemento[i] = g_inv_elemento[i + 1]
                g_inv_quantidade[i] = g_inv_quantidade[i + 1]
                g_inv_qtd_max[i] = g_inv_qtd_max[i + 1]
                g_inv_peso[i] = g_inv_peso[i + 1]
                g_inv_valor[i] = g_inv_valor[i + 1]
                g_inv_nivel_req[i] = g_inv_nivel_req[i + 1]
                g_inv_empilhavel[i] = g_inv_empilhavel[i + 1]
                g_inv_utilizavel[i] = g_inv_utilizavel[i + 1]
                g_inv_equipavel[i] = g_inv_equipavel[i + 1]
                g_inv_descartavel[i] = g_inv_descartavel[i + 1]
                g_inv_quest[i] = g_inv_quest[i + 1]
                g_inv_bonus_forca[i] = g_inv_bonus_forca[i + 1]
                g_inv_bonus_defesa[i] = g_inv_bonus_defesa[i + 1]
                g_inv_bonus_critico[i] = g_inv_bonus_critico[i + 1]
                g_inv_bonus_agi[i] = g_inv_bonus_agi[i + 1]
                g_inv_bonus_mana[i] = g_inv_bonus_mana[i + 1]
                g_inv_bonus_hp[i] = g_inv_bonus_hp[i + 1]
                g_inv_efeito_principal[i] = g_inv_efeito_principal[i + 1]
                g_inv_durabilidade[i] = g_inv_durabilidade[i + 1]
                g_inv_durabilidade_max[i] = g_inv_durabilidade_max[i + 1]
            }
            g_inv_slots_usados = g_inv_slots_usados - 1
        }
    }

    funcao usar_item(inteiro idx)
    {
        se (idx < 0 ou idx >= g_inv_slots_usados) { retorne }
        se (g_inv_utilizavel[idx] == falso) { retorne }
        se (g_inv_quantidade[idx] <= 0) { retorne }

        inteiro efeito = g_inv_efeito_principal[idx]
        inteiro valor = g_loja_valor_efeito[efeito - 1]

        se (efeito == 1) // Fome
        {
            g_fome = g_fome + valor
            se (g_fome > 100) { g_fome = 100 }
            escreva("[Item Usado] Voce recuperou ", valor, " de Fome.\n")
        }
        senao se (efeito == 2) // HP
        {
            inteiro cura = valor
            se (g_hp_atual + cura > g_hp_max) { cura = g_hp_max - g_hp_atual }
            g_hp_atual = g_hp_atual + cura
            escreva("[Item Usado] Voce recuperou ", cura, " HP.\n")
        }
        senao se (efeito == 3) // Mana
        {
            inteiro mana_rec = valor
            se (g_mana_atual + mana_rec > g_mana_max) { mana_rec = g_mana_max - g_mana_atual }
            g_mana_atual = g_mana_atual + mana_rec
            escreva("[Item Usado] Voce recuperou ", mana_rec, " MP.\n")
        }
        senao se (efeito == 4) // Stamina
        {
            g_stamina = g_stamina + valor
            se (g_stamina > 100) { g_stamina = 100 }
            escreva("[Item Usado] Voce recuperou ", valor, " Stamina.\n")
        }
        senao se (efeito == 5) // Reparar arma
        {
            g_arma_durabilidade = g_arma_durabilidade_max
            escreva("[Item Usado] Arma reparada completamente!\n")
        }
        senao se (efeito == 6) // Bomba de Luz
        {
            se (g_em_combate)
            {
                g_inim_stunned[g_combate_inimigo_idx] = verdadeiro
                escreva("[Bomba de Luz] Inimigo atordoado por 1 turno!\n")
            }
        }
        senao se (efeito == 8) // Coracao de Fenix (passivo)
        {
            escreva("[Coracao de Fenix] Item equipado como passivo.\n")
        }

        g_inv_quantidade[idx] = g_inv_quantidade[idx] - 1
        se (g_inv_quantidade[idx] <= 0)
        {
            remover_item(idx)
        }
    }

    funcao mostrar_inventario()
    {
        limpa()
        escreva("================================\n")
        escreva("         INVENTARIO\n")
        escreva("================================\n")
        escreva("Peso: ", g_peso_atual, " / ", calcular_peso_max(), "\n")
        escreva("Slots: ", g_inv_slots_usados, " / ", MAX_SLOTS, "\n")
        escreva("Ouro: ", g_ouro, "g\n")
        escreva("================================\n\n")

        se (g_inv_slots_usados == 0)
        {
            escreva("Inventario vazio.\n")
        }
        senao
        {
            inteiro i
            para (i = 0; i < g_inv_slots_usados; i = i + 1)
            {
                escreva("[", i + 1, "] ", g_inv_nome[i], " x", g_inv_quantidade[i])
                se (g_inv_equipavel[i]) { escreva(" [E]") }
                se (g_inv_utilizavel[i]) { escreva(" [U]") }
                escreva("\n")
            }
        }
        escreva("\n[0] Voltar\n")
        escreva("Escolha: ")
        inteiro choose
        leia(choose)
        se (choose > 0 e choose <= g_inv_slots_usados)
        {
            inteiro acao
            escreva("[1] Usar/Equipar [2] Descartar [3] Ver Detalhes: ")
            leia(acao)
            se (acao == 1)
            {
                se (g_inv_equipavel[choose - 1]) { equipar_item(choose - 1) }
                senao { usar_item(choose - 1) }
            }
            senao se (acao == 2)
            {
                se (g_inv_descartavel[choose - 1] e g_inv_quest[choose - 1] == falso)
                {
                    escreva("Confirmar descarte? [1] Sim [2] Nao: ")
                    leia(acao)
                    se (acao == 1)
                    {
                        escreva("[Item Descartado] ", g_inv_nome[choose - 1], "\n")
                        remover_item(choose - 1)
                    }
                }
            }
            senao se (acao == 3)
            {
                mostrar_detalhes_item(choose - 1)
            }
        }
    }

    funcao mostrar_detalhes_item(inteiro idx)
    {
        limpa()
        escreva("================================\n")
        escreva(g_inv_nome[idx], "\n")
        escreva("================================\n")
        escreva(g_inv_desc[idx], "\n")
        escreva("Raridade: ", nome_raridade(g_inv_raridade[idx]), "\n")
        escreva("Peso: ", g_inv_peso[idx], "\n")
        escreva("Valor: ", g_inv_valor[idx], "g\n")
        se (g_inv_bonus_forca[idx] > 0) { escreva("FOR: +", g_inv_bonus_forca[idx], "\n") }
        se (g_inv_bonus_defesa[idx] > 0) { escreva("DEF: +", g_inv_bonus_defesa[idx], "\n") }
        se (g_inv_bonus_critico[idx] > 0) { escreva("CRT: +", g_inv_bonus_critico[idx], "%\n") }
        escreva("================================\n")
        Util.aguarde(2000)
    }

    funcao equipar_item(inteiro idx)
    {
        se (idx < 0 ou idx >= g_inv_slots_usados) { retorne }
        // Equipar arma
        se (g_inv_tipo[idx] == 1)
        {
            g_arma_dano = g_arma_dano + g_inv_bonus_forca[idx]
            g_arma_nome = g_inv_nome[idx]
            escreva("[Equipado] ", g_inv_nome[idx], " como arma.\n")
        }
        // Equipar armadura
        se (g_inv_tipo[idx] == 2)
        {
            g_armadura_defesa = g_armadura_defesa + g_inv_bonus_defesa[idx]
            g_armadura_nome = g_inv_nome[idx]
            escreva("[Equipado] ", g_inv_nome[idx], " como armadura.\n")
        }
        Util.aguarde(1000)
    }

    funcao vender_item(inteiro idx)
    {
        se (idx < 0 ou idx >= g_inv_slots_usados) { retorne }
        se (g_inv_quest[idx]) { escreva("Item de quest nao pode ser vendido.\n") retorne }
        inteiro preco_venda = g_inv_valor[idx]
        se (g_inv_raridade[idx] == RAR_COMUM) { preco_venda = preco_venda * 30 / 100 }
        senao se (g_inv_raridade[idx] >= RAR_RARO) { preco_venda = preco_venda * 50 / 100 }
        senao se (g_inv_raridade[idx] >= RAR_LENDARIO) { preco_venda = preco_venda * 70 / 100 }
        g_ouro = g_ouro + preco_venda
        escreva("[Venda] Item vendido por ", preco_venda, " moedas.\n")
        remover_item(idx)
        Util.aguarde(1000)
    }

    funcao verificar_peso()
    {
        real peso_max = calcular_peso_max()
        real porcentagem = (g_peso_atual / peso_max) * 100.0
        se (porcentagem > 100.0)
        {
            escreva("[Peso Excessivo] Seu inventario esta muito pesado.\n")
        }
        senao se (porcentagem > 80.0)
        {
            escreva("[Pesado] Velocidade e esquiva reduzidas.\n")
        }
    }

    // ==========================================
    // SISTEMA DE COMBATE
    // ==========================================
    funcao inteiro gerar_inimigo(inteiro nivel, logico elite, logico boss)
    {
        inteiro idx = g_inim_count
        se (idx >= MAX_INIMIGOS) { retorne -1 }

        // Calcular stats base
        inteiro hp_base = 50 + (nivel * 22) + (nivel * nivel * 2)
        inteiro atk_base = 8 + (nivel * 3.5)
        inteiro def_base = 5 + (nivel * 2.2)

        se (boss)
        {
            hp_base = hp_base * 5
            atk_base = atk_base * 2.2
            def_base = def_base * 1.8
        }
        senao se (elite)
        {
            hp_base = hp_base * 2.2
            atk_base = atk_base * 1.5
            def_base = def_base * 1.4
        }

        // Gerar nome
        cadeia prefixos[8]
        prefixos[0] = "Selvagem"
        prefixos[1] = "Sombrio"
        prefixos[2] = "Antigo"
        prefixos[3] = "Corrompido"
        prefixos[4] = "Feroz"
        prefixos[5] = "Mistico"
        prefixos[6] = "Venenoso"
        prefixos[7] = "Glacial"

        cadeia tipos_inimigo[10]
        tipos_inimigo[0] = "Goblin"
        tipos_inimigo[1] = "Orc"
        tipos_inimigo[2] = "Esqueleto"
        tipos_inimigo[3] = "Lobo"
        tipos_inimigo[4] = "Aranha"
        tipos_inimigo[5] = "Morcego"
        tipos_inimigo[6] = "Slime"
        tipos_inimigo[7] = "Morto-vivo"
        tipos_inimigo[8] = "Demônio"
        tipos_inimigo[9] = "Elemental"

        cadeia chars_inimigo[10]
        chars_inimigo[0] = "G"
        chars_inimigo[1] = "O"
        chars_inimigo[2] = "S"
        chars_inimigo[3] = "W"
        chars_inimigo[4] = "A"
        chars_inimigo[5] = "B"
        chars_inimigo[6] = "L"
        chars_inimigo[7] = "Z"
        chars_inimigo[8] = "D"
        chars_inimigo[9] = "E"

        inteiro prefixo_idx = Util.sorteia(0, 7)
        inteiro tipo_idx = Util.sorteia(0, 9)

        g_inim_nome[idx] = prefixos[prefixo_idx] + " " + tipos_inimigo[tipo_idx]
        g_inim_char[idx] = chars_inimigo[tipo_idx]
        g_inim_hp_max[idx] = hp_base
        g_inim_hp_atual[idx] = hp_base
        g_inim_ataque[idx] = Matematica.arredondar(atk_base, 0)
        g_inim_defesa[idx] = Matematica.arredondar(def_base, 0)
        g_inim_inteligencia[idx] = nivel * 3
        g_inim_agilidade[idx] = nivel * 2
        g_inim_vitalidade[idx] = nivel * 4
        g_inim_critico[idx] = 5 + nivel
        g_inim_esquiva[idx] = 3 + nivel
        g_inim_resistencia[idx] = nivel * 2
        g_inim_elemento[idx] = Util.sorteia(1, 6)
        g_inim_xp[idx] = nivel * 15
        g_inim_ouro[idx] = (nivel * 4) + Util.sorteia(0, nivel * 3)
        g_inim_tipo[idx] = 1
        se (elite) { g_inim_tipo[idx] = 2 g_inim_xp[idx] = g_inim_xp[idx] * 2.5 g_inim_ouro[idx] = g_inim_ouro[idx] * 2 }
        se (boss) { g_inim_tipo[idx] = 3 g_inim_xp[idx] = g_inim_xp[idx] * 5 g_inim_ouro[idx] = g_inim_ouro[idx] * 5 }
        g_inim_stagger_max[idx] = hp_base / 4
        g_inim_stagger_atual[idx] = g_inim_stagger_max[idx]
        g_inim_stunned[idx] = falso

        g_inim_count = g_inim_count + 1
        retorne idx
    }

    funcao inteiro aplicar_dano(inteiro atacante_forca, inteiro atacante_precisao, inteiro atacante_critico, inteiro atacante_elemento, inteiro defensor_defesa, inteiro defensor_resistencia, inteiro defensor_elemento, inteiro skill_mult, logico forcar_critico)
    {
        // Verificar precisao
        inteiro chance_acerto = atacante_precisao
        inteiro roll = Util.sorteia(1, 100)
        se (roll > chance_acerto)
        {
            escreva("[Errou] O ataque errou o alvo!\n")
            retorne 0
        }

        // Calcular dano base
        real dano = atacante_forca * (skill_mult / 100.0)

        // Verificar critico
        logico foi_critico = falso
        inteiro crit_roll = Util.sorteia(1, 100)
        se (forcar_critico ou crit_roll <= atacante_critico)
        {
            dano = dano * 2.0
            foi_critico = verdadeiro
        }

        // Verificar elemento
        real elem_mult = verificar_fracao_elemental(atacante_elemento, defensor_elemento)
        dano = dano * elem_mult

        // Aplicar defesa
        inteiro reducao = calcular_reducao_dano(defensor_defesa)
        dano = dano - (dano * reducao / 100.0)

        // Aplicar resistencia magica
        se (skill_mult > 150)
        {
            dano = dano - (dano * defensor_resistencia * 0.25 / 100.0)
        }

        // Garantir dano minimo
        se (dano < 1) { dano = 1 }

        inteiro dano_final = Matematica.arredondar(dano, 0)

        se (foi_critico)
        {
            escreva("[CRITICO] ", dano_final, " de dano!\n")
        }
        senao
        {
            escreva("[Dano] ", dano_final, " de dano.\n")
        }

        se (elem_mult > 1.0)
        {
            escreva("[Super Eficaz] Dano elemental amplificado!\n")
        }
        senao se (elem_mult < 1.0)
        {
            escreva("[Resistente] Dano elemental reduzido.\n")
        }

        retorne dano_final
    }

    funcao gerar_combate(inteiro nivel_inimigo, logico elite, logico boss)
    {
        g_em_combate = verdadeiro
        g_combate_turno = 0
        g_turno_extra_rodada = falso

        // Gerar inimigo
        inteiro idx = gerar_inimigo(nivel_inimigo, elite, boss)
        se (idx == -1) { retorne }
        g_combate_inimigo_idx = idx

        cadeia tipo_texto = "Comum"
        se (elite) { tipo_texto = "ELITE" }
        se (boss) { tipo_texto = "BOSS" }

        limpa()
        escreva("================================\n")
        escreva("         COMBATE INICIADO\n")
        escreva("================================\n")
        escreva(tipo_texto, ": ", g_inim_nome[idx], "\n")
        escreva("HP: ", g_inim_hp_atual[idx], "/", g_inim_hp_max[idx], "\n")
        escreva("Elemento: ", nome_elemento(g_inim_elemento[idx]), "\n")
        escreva("================================\n")
        Util.aguarde(1500)

        // Loop de combate
        enquanto (g_em_combate)
        {
            g_combate_turno = g_combate_turno + 1

            // Turno do jogador
            turno_jogador()

            // Verificar se inimigo morreu
            se (g_inim_hp_atual[idx] <= 0)
            {
                combate_vitoria(idx)
                retorne
            }

            // Verificar se jogador morreu
            se (g_hp_atual <= 0)
            {
                combate_derrota()
                retorne
            }

            // Turno do inimigo
            turno_inimigo(idx)

            // Verificar se jogador morreu
            se (g_hp_atual <= 0)
            {
                combate_derrota()
                retorne
            }

            // Atualizar efeitos
            atualizar_efeitos_jogador()
            processar_efeitos_turno_jogador()

            // Reduzir cooldowns
            reduzir_cooldowns()

            // Resetar turno extra
            g_turno_extra_rodada = falso

            // Atualizar HUD
            mostrar_hud_combate(idx)
        }
    }

    funcao turno_jogador()
    {
        inteiro idx = g_combate_inimigo_idx
        limpa()
        mostrar_hud_combate(idx)
        escreva("\n[1] Atacar\n")
        escreva("[2] Habilidades\n")
        escreva("[3] Itens\n")
        escreva("[4] Fugir\n")
        escreva("Escolha: ")
        inteiro chooses
        leia(chooses)

        se (chooses == 1)
        {
            atacar_basico(idx)
        }
        senao se (chooses == 2)
        {
            menu_habilidades(idx)
        }
        senao se (chooses == 3)
        {
            menu_itens_combate()
        }
        senao se (chooses == 4)
        {
            tentar_fugir()
        }
    }

    funcao atacar_basico(inteiro idx)
    {
        // Verificar durabilidade da arma
        inteiro mult_dano = 100
        se (g_arma_durabilidade <= 0) { mult_dano = 10 }

        inteiro ataque_total = calcular_ataque_total()
        dano = aplicar_dano(ataque_total, g_precisao, calcular_critico_total(), g_arma_elemento, g_inim_defesa[idx], g_inim_resistencia[idx], g_inim_elemento[idx], mult_dano, falso)

        g_inim_hp_atual[idx] = g_inim_hp_atual[idx] - dano
        g_dano_total_causado = g_dano_total_causado + dano

        // Reduzir durabilidade
        g_arma_durabilidade = g_arma_durabilidade - 1
        se (g_arma_durabilidade < 0) { g_arma_durabilidade = 0 }

        // Aplicar stagger
        aplicar_stagger(idx, 15)

        g_acoes_totais = g_acoes_totais + 1
        verificar_ciclo_tempo()
        Util.aguarde(1000)
    }

    funcao menu_habilidades(inteiro idx)
    {
        limpa()
        escreva("================================\n")
        escreva("        HABILIDADES\n")
        escreva("================================\n")

        // Calcular skills disponiveis por classe
        inteiro skill_base = (g_classe_jogador - 1) * 5
        inteiro skills_desbloqueadas = g_nivel
        se (skills_desbloqueadas > 5) { skills_desbloqueadas = 5 }

        inteiro i
        para (i = 0; i < skills_desbloqueadas; i = i + 1)
        {
            inteiro skill_idx = skill_base + i
            cadeia status = "OK"
            se (g_skill_cooldown_atual[skill_idx] > 0) { status = "CD:" + g_skill_cooldown_atual[skill_idx] }
            se (g_mana_atual < g_skill_custo[skill_idx]) { status = "SEM MANA" }
            escreva("[", i + 1, "] ", g_skill_nome[skill_idx], " (", g_skill_custo[skill_idx], " MP) [", status, "]\n")
        }
        escreva("[0] Voltar\n")
        escreva("Escolha: ")
        inteiro choosen
        leia(choosen)

        se (choosen == 0) { retorne }
        se (choosen < 1 ou choosen > skills_desbloqueadas) { retorne }

        inteiro skill_idx = skill_base + choosen - 1

        // Verificar cooldown
        se (g_skill_cooldown_atual[skill_idx] > 0)
        {
            escreva("Habilidade em cooldown!\n")
            Util.aguarde(1000)
            retorne
        }

        // Verificar mana
        se (g_mana_atual < g_skill_custo[skill_idx])
        {
            escreva("Mana insuficiente!\n")
            Util.aguarde(1000)
            retorne
        }

        usar_habilidade(skill_idx, idx)
    }

    funcao usar_habilidade(inteiro skill_idx, inteiro inimigo_idx)
    {
        // Consumir mana
        g_mana_atual = g_mana_atual - g_skill_custo[skill_idx]

        // Aplicar cooldown
        g_skill_cooldown_atual[skill_idx] = g_skill_cooldown[skill_idx]

        inteiro tipo = g_skill_tipo[skill_idx]
        inteiro mult = g_skill_dano_mult[skill_idx]
        cadeia nome_skill = g_skill_nome[skill_idx]

        escreva("\n[", nome_skill, "]\n")

        // Tipo 1 = Dano fisico
        se (tipo == 1)
        {
            // Verificar durabilidade
            inteiro mult_final = mult
            se (g_arma_durabilidade <= 0) { mult_final = mult / 10 }

            inteiro ataque_total = calcular_ataque_total()
            dano = aplicar_dano(ataque_total, g_precisao, calcular_critico_total(), g_arma_elemento, g_inim_defesa[inimigo_idx], g_inim_resistencia[inimigo_idx], g_inim_elemento[inimigo_idx], mult_final, falso)

            g_inim_hp_atual[inimigo_idx] = g_inim_hp_atual[inimigo_idx] - dano
            g_dano_total_causado = g_dano_total_causado + dano
            g_arma_durabilidade = g_arma_durabilidade - 2

            // Execucao - bonus se alvo < 30%
            se (skill_idx == 4)
            {
                real hp_pct = (g_inim_hp_atual[inimigo_idx] + 0.0) / g_inim_hp_max[inimigo_idx]
                se (hp_pct < 0.3)
                {
                    inteiro dano_extra = g_inim_hp_max[inimigo_idx] * 30 / 100
                    se (dano_extra > dano * 2) { dano_extra = dano * 2 }
                    g_inim_hp_atual[inimigo_idx] = g_inim_hp_atual[inimigo_idx] - dano_extra
                    escreva("[Execucao] Dano amplificado!\n")
                }
            }
        }

        // Tipo 2 = Buff defensivo
        se (tipo == 2)
        {
            se (skill_idx == 1) // Postura Defensiva
            {
                aplicar_buff("Postura Defensiva", 3, 40, 3)
                escreva("[Postura Defensiva] Reducao de dano +40% por 3 turnos.\n")
            }
            se (skill_idx == 6) // Escudo Arcano
            {
                inteiro escudo = 50 + g_inteligencia * 2
                aplicar_buff("Escudo Arcano", 4, escudo, 4)
                escreva("[Escudo Arcano] Barreira de ", escudo, " HP.\n")
            }
            se (skill_idx == 11) // Esquiva
            {
                aplicar_buff("Esquiva Aprimorada", 2, 40, 5)
                escreva("[Esquiva] +40% evasao por 2 turnos.\n")
            }
            se (skill_idx == 17) // Aura de Protecao
            {
                aplicar_buff("Aura de Protecao", 999, 20, 6)
                escreva("[Aura de Protecao] +20 Defesa permanente.\n")
            }
        }

        // Tipo 3 = Buff ataque
        se (tipo == 3)
        {
            aplicar_buff("Grito de Guerra", 4, 25, 7)
            escreva("[Grito de Guerra] +25% dano por 4 turnos.\n")
        }

        // Tipo 4 = Dano magico
        se (tipo == 4)
        {
            inteiro poder_magico = g_inteligencia * 2
            dano = aplicar_dano(poder_magico, g_precisao, calcular_critico_total(), g_skill_elemento[skill_idx], g_inim_defesa[inimigo_idx], g_inim_resistencia[inimigo_idx], g_inim_elemento[inimigo_idx], mult, falso)
            g_inim_hp_atual[inimigo_idx] = g_inim_hp_atual[inimigo_idx] - dano
            g_dano_total_causado = g_dano_total_causado + dano

            // Tempestade - chance de choque
            se (skill_idx == 8)
            {
                se (Util.sorteia(1, 100) <= 20)
                {
                    aplicar_debuff("Choque", 2, 10, 4)
                    escreva("[Choque] Inimigo eletrificado!\n")
                }
            }
        }

        // Tipo 5 = Debuff ambiente
        se (tipo == 5)
        {
            g_ambiente_atual = "Nevasca"
            aplicar_debuff("Nevasca", 5, 30, 5)
            escreva("[Nevasca] Precisao do inimigo -30% por 5 turnos.\n")
        }

        // Tipo 6 = Dreno de mana
        se (tipo == 6)
        {
            inteiro poder_magico = g_inteligencia * 2
            dano = aplicar_dano(poder_magico, g_precisao, calcular_critico_total(), ELEM_NEUTRO, g_inim_defesa[inimigo_idx], g_inim_resistencia[inimigo_idx], g_inim_elemento[inimigo_idx], mult, falso)
            g_inim_hp_atual[inimigo_idx] = g_inim_hp_atual[inimigo_idx] - dano
            g_dano_total_causado = g_dano_total_causado + dano
            inteiro mana_rec = g_skill_custo[skill_idx] / 2
            se (g_mana_atual + mana_rec > g_mana_max) { mana_rec = g_mana_max - g_mana_atual }
            g_mana_atual = g_mana_atual + mana_rec
            escreva("[Dreno] Recuperou ", mana_rec, " MP.\n")
        }

        // Tipo 7 = Punhalada (critico)
        se (tipo == 7)
        {
            inteiro ataque_total = calcular_ataque_total()
            dano = aplicar_dano(ataque_total, g_precisao, 50, g_arma_elemento, g_inim_defesa[inimigo_idx], g_inim_resistencia[inimigo_idx], g_inim_elemento[inimigo_idx], mult, falso)
            g_inim_hp_atual[inimigo_idx] = g_inim_hp_atual[inimigo_idx] - dano
            g_dano_total_causado = g_dano_total_causado + dano
            g_arma_durabilidade = g_arma_durabilidade - 1
        }

        // Tipo 8 = Invisibilidade
        se (tipo == 8)
        {
            aplicar_buff("Invisibilidade", 1, 100, 8)
            escreva("[Invisibilidade] Voce desapareceu nas sombras.\n")
        }

        // Tipo 9 = Veneno
        se (tipo == 9)
        {
            inteiro dano_veneno = 4
            se (g_inim_tipo[inimigo_idx] == 2) { dano_veneno = 2 }
            se (g_inim_tipo[inimigo_idx] == 3) { dano_veneno = 1 }
            aplicar_debuff("Veneno", 5, dano_veneno, 1)
            escreva("[Veneno] Inimigo envenenado!\n")
        }

        // Tipo 10 = Assalto
        se (tipo == 10)
        {
            inteiro ataque_total = calcular_ataque_total()
            dano = aplicar_dano(ataque_total, g_precisao, calcular_critico_total(), g_arma_elemento, g_inim_defesa[inimigo_idx], g_inim_resistencia[inimigo_idx], g_inim_elemento[inimigo_idx], mult, falso)
            g_inim_hp_atual[inimigo_idx] = g_inim_hp_atual[inimigo_idx] - dano
            g_dano_total_causado = g_dano_total_causado + dano
            inteiro cura = dano * 15 / 100
            se (g_hp_atual + cura > g_hp_max) { cura = g_hp_max - g_hp_atual }
            g_hp_atual = g_hp_atual + cura
            escreva("[Assalto] Recuperou ", cura, " HP.\n")
        }

        // Tipo 11 = Cura
        se (tipo == 11)
        {
            inteiro cura = g_hp_max * 30 / 100
            se (g_hp_atual + cura > g_hp_max) { cura = g_hp_max - g_hp_atual }
            g_hp_atual = g_hp_atual + cura
            escreva("[Cura Sagrada] Recuperou ", cura, " HP.\n")
        }

        // Tipo 12 = Julgamento
        se (tipo == 12)
        {
            inteiro ataque_total = calcular_ataque_total()
            dano = aplicar_dano(ataque_total, g_precisao, calcular_critico_total(), ELEM_LUZ, g_inim_defesa[inimigo_idx], g_inim_resistencia[inimigo_idx], g_inim_elemento[inimigo_idx], mult, falso)
            g_inim_hp_atual[inimigo_idx] = g_inim_hp_atual[inimigo_idx] - dano
            g_dano_total_causado = g_dano_total_causado + dano
            aplicar_debuff("Julgamento", 1, 50, 6)
            escreva("[Julgamento] Ataque do inimigo reduzido!\n")
        }

        // Tipo 13 = Ressurreicao
        se (tipo == 13)
        {
            escreva("[Ressurreicao] Habilidade passiva - sera usada ao morrer.\n")
        }

        // Tipo 14 = Olho de Aguia
        se (tipo == 14)
        {
            aplicar_buff("Olho de Aguia", 1, 100, 9)
            escreva("[Olho de Aguia] Proximo ataque sera critico!\n")
        }

        // Tipo 15 = Armadilha (stun)
        se (tipo == 15)
        {
            se (g_inim_tipo[inimigo_idx] == 3)
            {
                se (Util.sorteia(1, 100) <= 50)
                {
                    g_inim_stunned[inimigo_idx] = verdadeiro
                    escreva("[Armadilha] Boss parcialmente atordoado!\n")
                }
            }
            senao
            {
                g_inim_stunned[inimigo_idx] = verdadeiro
                escreva("[Armadilha] Inimigo atordoado por 1 turno!\n")
            }
        }

        // Tipo 16 = Flecha Vampirica
        se (tipo == 16)
        {
            inteiro ataque_total = calcular_ataque_total()
            dano = aplicar_dano(ataque_total, g_precisao, calcular_critico_total(), g_arma_elemento, g_inim_defesa[inimigo_idx], g_inim_resistencia[inimigo_idx], g_inim_elemento[inimigo_idx], mult, falso)
            g_inim_hp_atual[inimigo_idx] = g_inim_hp_atual[inimigo_idx] - dano
            g_dano_total_causado = g_dano_total_causado + dano
            inteiro roubo = dano
            se (g_inim_tipo[inimigo_idx] == 3) { roubo = roubo / 2 }
            se (g_hp_atual + roubo > g_hp_max) { roubo = g_hp_max - g_hp_atual }
            g_hp_atual = g_hp_atual + roubo
            escreva("[Flecha Vampirica] Drenou ", roubo, " HP.\n")
        }

        // Tipo 17 = Reflexao
        se (tipo == 17)
        {
            aplicar_buff("Pele de Arvore", 4, 20, 10)
            escreva("[Pele de Arvore] 20% reflexao de dano.\n")
        }

        // Tipo 18 = Regeneracao
        se (tipo == 18)
        {
            inteiro regen = 6
            se (g_mapa_regiao_atual == "Floresta Sombria") { regen = 9 }
            aplicar_buff("Crescimento Exuberante", 5, regen, 1)
            escreva("[Crescimento] Regeneracao de ", regen, " HP/turno.\n")
        }

        // Tipo 19 = Forma de Urso
        se (tipo == 19)
        {
            aplicar_buff("Forma de Urso", 4, 35, 11)
            g_hp_max = g_hp_max + (g_hp_max * 35 / 100)
            g_hp_atual = g_hp_atual + (g_hp_max * 35 / 100)
            escreva("[Forma de Urso] HP +35% por 4 turnos.\n")
        }

        // Tipo 20 = Toque Sombrio
        se (tipo == 20)
        {
            inteiro poder_magico = g_inteligencia * 2
            dano = aplicar_dano(poder_magico, g_precisao, calcular_critico_total(), ELEM_TREVAS, g_inim_defesa[inimigo_idx], g_inim_resistencia[inimigo_idx], g_inim_elemento[inimigo_idx], mult, falso)
            g_inim_hp_atual[inimigo_idx] = g_inim_hp_atual[inimigo_idx] - dano
            g_dano_total_causado = g_dano_total_causado + dano
            aplicar_debuff("Toque Sombrio", 3, 15, 7)
            escreva("[Toque Sombrio] Defesa do inimigo reduzida.\n")
        }

        // Tipo 21 = Erguer Esqueleto
        se (tipo == 21)
        {
            aplicar_buff("Esqueleto Invocado", 4, g_inteligencia * 35 / 100, 12)
            escreva("[Esqueleto] Invocacao por 4 turnos.\n")
        }

        // Tipo 22 = Maldicao
        se (tipo == 22)
        {
            inteiro dur = 3
            inteiro intensidade = 50
            se (g_inim_tipo[inimigo_idx] == 3) { intensidade = 25 }
            aplicar_debuff("Maldicao", dur, intensidade, 8)
            escreva("[Maldicao] Inimigo recebe +", intensidade, "% dano.\n")
        }

        // Tipo 23 = Sacrificio
        se (tipo == 23)
        {
            inteiro custo_hp = g_hp_atual * 20 / 100
            se (g_hp_atual - custo_hp <= 1) { custo_hp = g_hp_atual - 1 }
            g_hp_atual = g_hp_atual - custo_hp
            dano = custo_hp * 3
            g_inim_hp_atual[inimigo_idx] = g_inim_hp_atual[inimigo_idx] - dano
            g_dano_total_causado = g_dano_total_causado + dano
            escreva("[Sacrificio] Dano de ", dano, "!\n")
        }

        // Tipo 24 = Colheita de Almas
        se (tipo == 24)
        {
            se (g_inim_hp_atual[inimigo_idx] <= dano)
            {
                g_mana_atual = g_mana_max
                g_hp_atual = g_hp_atual + (g_hp_max / 2)
                escreva("[Colheita] Alma colhida! Mana e HP restaurados.\n")
            }
            senao
            {
                inteiro poder_magico = g_inteligencia * 2
                dano = aplicar_dano(poder_magico, g_precisao, calcular_critico_total(), ELEM_TREVAS, g_inim_defesa[inimigo_idx], g_inim_resistencia[inimigo_idx], g_inim_elemento[inimigo_idx], 200, falso)
                g_inim_hp_atual[inimigo_idx] = g_inim_hp_atual[inimigo_idx] - dano
                g_dano_total_causado = g_dano_total_causado + dano
            }
        }

        // Tipo 25 = Palma de Ferro (ignora armadura)
        se (tipo == 25)
        {
            inteiro ataque_total = calcular_ataque_total()
            dano = ataque_total * mult / 100
            g_inim_hp_atual[inimigo_idx] = g_inim_hp_atual[inimigo_idx] - dano
            g_dano_total_causado = g_dano_total_causado + dano
            escreva("[Palma de Ferro] ", dano, " de dano (ignora armadura)!\n")
        }

        // Tipo 26 = Meditacao
        se (tipo == 26)
        {
            inteiro hp_rec = g_hp_max * 20 / 100
            inteiro mana_rec = g_mana_max * 20 / 100
            se (g_hp_atual + hp_rec > g_hp_max) { hp_rec = g_hp_max - g_hp_atual }
            se (g_mana_atual + mana_rec > g_mana_max) { mana_rec = g_mana_max - g_mana_atual }
            g_hp_atual = g_hp_atual + hp_rec
            g_mana_atual = g_mana_atual + mana_rec
            escreva("[Meditacao] Recuperou ", hp_rec, " HP e ", mana_rec, " MP.\n")
        }

        // Tipo 27 = Chute Relampago (turno extra)
        se (tipo == 27)
        {
            inteiro ataque_total = calcular_ataque_total()
            dano = aplicar_dano(ataque_total, g_precisao, calcular_critico_total(), g_arma_elemento, g_inim_defesa[inimigo_idx], g_inim_resistencia[inimigo_idx], g_inim_elemento[inimigo_idx], mult, falso)
            g_inim_hp_atual[inimigo_idx] = g_inim_hp_atual[inimigo_idx] - dano
            g_dano_total_causado = g_dano_total_causado + dano
            se (g_turno_extra_rodada == falso)
            {
                g_turno_extra_rodada = verdadeiro
                escreva("[Chute Relampago] Turno extra!\n")
                turno_jogador()
            }
            senao
            {
                escreva("[Chute Relampago] Sem turno extra disponivel.\n")
            }
        }

        // Tipo 28 = Desviar Projeteis
        se (tipo == 28)
        {
            aplicar_buff("Desviar Projeteis", 1, 100, 13)
            escreva("[Desviar] Proximo ataque sera bloqueado.\n")
        }

        // Tipo 29 = Golpe do Ponto Vital
        se (tipo == 29)
        {
            inteiro ataque_total = calcular_ataque_total()
            dano = ataque_total * mult / 100
            g_inim_hp_atual[inimigo_idx] = g_inim_hp_atual[inimigo_idx] - dano
            g_dano_total_causado = g_dano_total_causado + dano
            aplicar_stagger(inimigo_idx, 70)
            escreva("[Ponto Vital] ", dano, " de dano + stagger!\n")
        }

        g_acoes_totais = g_acoes_totais + 1
        verificar_ciclo_tempo()
        Util.aguarde(1000)
    }

    funcao menu_itens_combate()
    {
        limpa()
        escreva("================================\n")
        escreva("         ITENS\n")
        escreva("================================\n")

        inteiro i
        inteiro count = 0
        para (i = 0; i < g_inv_slots_usados; i = i + 1)
        {
            se (g_inv_utilizavel[i] e g_inv_quantidade[i] > 0)
            {
                escreva("[", count + 1, "] ", g_inv_nome[i], " x", g_inv_quantidade[i], "\n")
                count = count + 1
            }
        }

        se (count == 0)
        {
            escreva("Nenhum item utilizavel.\n")
        }
        escreva("[0] Voltar\n")
        escreva("Escolha: ")
        inteiro chose
        leia(chose)

        se (chose > 0 e chose <= count)
        {
            // Encontrar o item real
            inteiro atual = 0
            para (i = 0; i < g_inv_slots_usados; i = i + 1)
            {
                se (g_inv_utilizavel[i] e g_inv_quantidade[i] > 0)
                {
                    atual = atual + 1
                    se (atual == chose)
                    {
                        usar_item(i)
                        g_acoes_totais = g_acoes_totais + 1
                        verificar_ciclo_tempo()
                        retorne
                    }
                }
            }
        }
    }

    funcao tentar_fugir()
    {
        inteiro chance = 50 + g_agilidade
        se (g_inim_tipo[g_combate_inimigo_idx] == 3) { chance = 20 }
        se (Util.sorteia(1, 100) <= chance)
        {
            escreva("Voce fugiu com sucesso!\n")
            g_em_combate = falso
            Util.aguarde(1000)
        }
        senao
        {
            escreva("Falha ao fugir!\n")
            Util.aguarde(1000)
        }
    }

    funcao turno_inimigo(inteiro idx)
    {
        // Verificar stun
        se (g_inim_stunned[idx])
        {
            escreva(g_inim_nome[idx], " esta atordoado e perdeu o turno!\n")
            g_inim_stunned[idx] = falso
            Util.aguarde(1000)
            retorne
        }

        // Verificar stagger
        se (g_inim_stagger_atual[idx] <= 0)
        {
            escreva(g_inim_nome[idx], " esta atordoado pelo stagger!\n")
            g_inim_stagger_atual[idx] = g_inim_stagger_max[idx] / 2
            Util.aguarde(1000)
            retorne
        }

        // IA do inimigo
        ia_inimigo(idx)

        Util.aguarde(1000)
    }

    funcao ia_inimigo(inteiro idx)
    {
        real hp_pct = (g_inim_hp_atual[idx] + 0.0) / g_inim_hp_max[idx]

        // Prioridade 1: Curar se HP < 30%
        se (hp_pct < 0.3 e Util.sorteia(1, 100) <= 30)
        {
            inteiro cura = g_inim_hp_max[idx] * 10 / 100
            g_inim_hp_atual[idx] = g_inim_hp_atual[idx] + cura
            escreva(g_inim_nome[idx], " se cura! +", cura, " HP.\n")
            retorne
        }

        // Prioridade 2: Buff se combate longo
        se (g_combate_turno > 5 e Util.sorteia(1, 100) <= 20)
        {
            escreva(g_inim_nome[idx], " se fortalece!\n")
            g_inim_ataque[idx] = g_inim_ataque[idx] + 5
            retorne
        }

        // Ataque normal
        inteiro ataque = g_inim_ataque[idx]

        // Verificar esquiva do jogador
        inteiro esquiva_total = calcular_esquiva_total()
        se (possui_buff(5)) { esquiva_total = esquiva_total + 40 }
        se (g_ciclo_dia_noite == "Nevasca") { esquiva_total = esquiva_total - 30 }

        se (Util.sorteia(1, 100) <= esquiva_total)
        {
            escreva("[Esquiva] Voce desviou do ataque!\n")
            retorne
        }

        // Verificar desviar projeteis
        se (possui_buff(13))
        {
            escreva("[Desviar] Voce bloqueou o ataque!\n")
            retorne
        }

        // Calcular dano
        real dano = ataque
        inteiro def_total = calcular_defesa_total()
        inteiro reducao = calcular_reducao_dano(def_total)
        dano = dano - (dano * reducao / 100.0)

        // Noite: +30% dano
        se (g_ciclo_dia_noite == "Noite") { dano = dano * 1.3 }

        se (dano < 1) { dano = 1 }
        inteiro dano_final = Matematica.arredondar(dano, 0)

        // Verificar buff de reducao
        se (possui_buff(3)) { dano_final = dano_final * 60 / 100 }

        g_hp_atual = g_hp_atual - dano_final
        escreva(g_inim_nome[idx], " causa ", dano_final, " de dano!\n")

        // Verificar reflexao
        se (possui_buff(10))
        {
            inteiro reflexao = dano_final * 20 / 100
            g_inim_hp_atual[idx] = g_inim_hp_atual[idx] - reflexao
            escreva("[Reflexao] ", reflexao, " de dano refletido!\n")
        }
    }

    funcao aplicar_stagger(inteiro idx, inteiro valor)
    {
        se (g_inim_tipo[idx] == 3) { valor = valor / 4 }
        g_inim_stagger_atual[idx] = g_inim_stagger_atual[idx] - valor
        se (g_inim_stagger_atual[idx] < 0) { g_inim_stagger_atual[idx] = 0 }
    }

    funcao reduzir_cooldowns()
    {
        inteiro i
        para (i = 0; i < g_skill_count; i = i + 1)
        {
            se (g_skill_cooldown_atual[i] > 0)
            {
                g_skill_cooldown_atual[i] = g_skill_cooldown_atual[i] - 1
            }
        }
    }

    funcao combate_vitoria(inteiro idx)
    {
        g_em_combate = falso
        g_combates_vencidos = g_combates_vencidos + 1
        g_inimigos_mortos = g_inimigos_mortos + 1

        // Verificar tipo
        cadeia tipo_texto = ""
        se (g_inim_tipo[idx] == 2) { tipo_texto = " ELITE" }
        se (g_inim_tipo[idx] == 3) { tipo_texto = " BOSS" g_bosses_derrotados = g_bosses_derrotados + 1 }

        limpa()
        escreva("================================\n")
        escreva("         VITORIA", tipo_texto, "!\n")
        escreva("================================\n")

        // Calcular XP
        inteiro xp_ganho = g_inim_xp[idx]
        se (g_ciclo_dia_noite == "Noite") { xp_ganho = xp_ganho * 1.5 }
        escreva("XP: +", xp_ganho, "\n")

        // Calcular ouro
        inteiro ouro_ganho = g_inim_ouro[idx]
        se (g_ciclo_dia_noite == "Noite") { ouro_ganho = ouro_ganho * 1.5 }
        escreva("Ouro: +", ouro_ganho, "\n")

        g_xp = g_xp + xp_ganho
        g_ouro = g_ouro + ouro_ganho

        // Gerar loot
        gerar_loot(idx)

        // Atualizar quests
        atualizar_quests_combate()

        // Verificar level up
        check_lvl()

        escreva("================================\n")
        Util.aguarde(2000)
    }

    funcao combate_derrota()
    {
        g_em_combate = falso

        // Verificar Coracao de Fenix
        inteiro i
        para (i = 0; i < g_inv_slots_usados; i = i + 1)
        {
            se (g_inv_efeito_principal[i] == 8 e g_inv_quantidade[i] > 0)
            {
                g_hp_atual = g_hp_max * 20 / 100
                g_inv_quantidade[i] = g_inv_quantidade[i] - 1
                se (g_inv_quantidade[i] <= 0) { remover_item(i) }
                escreva("[Coracao de Fenix] Voce reviveu com 20% HP!\n")
                Util.aguarde(2000)
                retorne
            }
        }

        // Verificar Ressurreicao do Paladino
        se (g_classe_jogador == CLS_PALADINO)
        {
            se (g_skill_cooldown_atual[19] == 0)
            {
                g_hp_atual = g_hp_max
                g_skill_cooldown_atual[19] = 999
                escreva("[Ressurreicao] Voce foi revivido!\n")
                Util.aguarde(2000)
                retorne
            }
        }

        limpa()
        escreva("================================\n")
        escreva("         DERROTA\n")
        escreva("================================\n")
        escreva("Voce foi derrotado...\n")
        escreva("Perdeu 20% do ouro.\n")
        g_ouro = g_ouro * 80 / 100
        g_hp_atual = g_hp_max / 2
        g_mana_atual = g_mana_max / 2
        escreva("================================\n")
        Util.aguarde(3000)
    }

    funcao gerar_loot(inteiro inimigo_idx)
    {
        inteiro roll = Util.sorteia(1, 100)
        inteiro raridade = RAR_COMUM

        se (roll <= 1) { raridade = RAR_MITICO }
        senao se (roll <= 2) { raridade = RAR_LENDARIO }
        senao se (roll <= 6) { raridade = RAR_EPICO }
        senao se (roll <= 16) { raridade = RAR_RARO }
        senao se (roll <= 41) { raridade = RAR_INCOMUM }

        cadeia prefixos[6]
        prefixos[0] = "Velha"
        prefixos[1] = "Afiada"
        prefixos[2] = "Brilhante"
        prefixos[3] = "Sombria"
        prefixos[4] = "Antiga"
        prefixos[5] = "Amaldicoada"

        cadeia tipos_loot[6]
        tipos_loot[0] = "Espada"
        tipos_loot[1] = "Arco"
        tipos_loot[2] = "Cajado"
        tipos_loot[3] = "Armadura"
        tipos_loot[4] = "Amuleto"
        tipos_loot[5] = "Anel"

        inteiro prefixo_idx = Util.sorteia(0, 5)
        inteiro tipo_idx = Util.sorteia(0, 5)

        cadeia nome_item = prefixos[prefixo_idx] + " " + tipos_loot[tipo_idx]
        inteiro valor = g_nivel * 20 * raridade
        inteiro bonus = raridade * 3

        se (tipo_idx <= 2) // Arma
        {
            adicionar_item(nome_item, "Arma " + nome_raridade(raridade), "Equipamento", raridade, 1, ELEM_NEUTRO, 1, 5.0, valor, 1, falso, falso, verdadeiro, verdadeiro, falso, bonus, 0, 0, 0, 0, 0, 0)
        }
        senao se (tipo_idx == 3) // Armadura
        {
            adicionar_item(nome_item, "Armadura " + nome_raridade(raridade), "Equipamento", raridade, 2, ELEM_NEUTRO, 1, 8.0, valor, 1, falso, falso, verdadeiro, verdadeiro, falso, 0, bonus, 0, 0, 0, 0, 0)
        }
        senao // Acessorio
        {
            adicionar_item(nome_item, "Acessorio " + nome_raridade(raridade), "Equipamento", raridade, 3, ELEM_NEUTRO, 1, 1.0, valor, 1, falso, falso, verdadeiro, verdadeiro, falso, bonus / 2, bonus / 2, bonus, bonus / 2, bonus, bonus * 5, 0)
        }

        escreva("[Loot] ", nome_item, " obtido!\n")
    }

    // ==========================================
    // SISTEMA DE LEVEL UP
    // ==========================================
    funcao check_lvl()
    {
        enquanto (g_xp >= g_xp_proximo e g_nivel < LEVEL_MAX)
        {
            g_nivel = g_nivel + 1
            g_xp = g_xp - g_xp_proximo
            g_xp_proximo = calcular_xp_proximo()

            // Atribuir pontos
            g_forca = g_forca + 2
            g_defesa = g_defesa + 2
            g_inteligencia = g_inteligencia + 2
            g_agilidade = g_agilidade + 2
            g_vitalidade = g_vitalidade + 2

            // Recalcular stats
            g_hp_max = calcular_hp_max()
            g_mana_max = calcular_mana_max()
            g_hp_atual = g_hp_max
            g_mana_atual = g_mana_max

            limpa()
            escreva("================================\n")
            escreva("         LEVEL UP!\n")
            escreva("================================\n")
            escreva("Nivel: ", g_nivel, "\n")
            escreva("HP Max: ", g_hp_max, "\n")
            escreva("Mana Max: ", g_mana_max, "\n")
            escreva("================================\n")

            // Desbloquear habilidade
            se (g_nivel <= 5)
            {
                escreva("Nova habilidade desbloqueada!\n")
            }

            Util.aguarde(2000)

            // Salvar ao upar
            salvar_jogo()
        }
    }

    // ==========================================
    // SISTEMA DE LOJA
    // ==========================================
    funcao loja()
    {
        limpa()
        escreva("================================\n")
        escreva("            LOJA\n")
        escreva("================================\n")
        escreva("Ouro: ", g_ouro, "g\n")
        escreva("Reputacao: ", g_reputacao, " (Desconto: ", g_desconto, "%)\n")
        escreva("================================\n")
        escreva("[1] Consumiveis\n")
        escreva("[2] Equipamentos/Upgrades\n")
        escreva("[3] Vender Itens\n")
        escreva("[0] Sair\n")
        escreva("Escolha: ")
        inteiro chosen
        leia(chosen)

        se (chosen == 1) { loja_consumiveis() }
        senao se (chosen == 2) { loja_upgrades() }
        senao se (chosen == 3) { menu_venda() }
    }

    funcao loja_consumiveis()
    {
        limpa()
        escreva("================================\n")
        escreva("        CONSUMIVEIS\n")
        escreva("================================\n")

        inteiro i
        para (i = 0; i < g_loja_count; i = i + 1)
        {
            se (g_loja_categoria[i] == CAT_CONSUMIVEL ou g_loja_categoria[i] == CAT_ESPECIAL)
            {
                // Verificar nivel
                se (g_nivel < g_loja_nivel_req[i]) { escreva("") }

                // Verificar mercador negro
                se (i >= 11 e g_ciclo_dia_noite == "Dia") { escreva("") }

                inteiro preco = g_loja_preco[i]
                // Inflacao noturna
                se (g_ciclo_dia_noite == "Noite" e g_loja_categoria[i] == CAT_CONSUMIVEL) { preco = preco * 125 / 100 }
                se (g_ciclo_dia_noite == "Noite" e i >= 11) { preco = preco * 80 / 100 }
                // Desconto reputacao
                preco = preco - (preco * g_desconto / 100)

                escreva("[", i + 1, "] ", g_loja_nome[i], " - ", preco, "g\n")
                escreva("    ", g_loja_desc[i], "\n")
            }
        }
        escreva("[0] Voltar\n")
        escreva("Escolha: ")
        inteiro chse
        leia(chse)

        se (chse > 0 e chse <= g_loja_count)
        {
            inteiro idx = chse - 1
            se (g_nivel < g_loja_nivel_req[idx])
            {
                escreva("Nivel insuficiente!\n")
                Util.aguarde(1000)
                retorne
            }
            se (idx >= 11 e g_ciclo_dia_noite == "Dia")
            {
                escreva("Item disponivel apenas a noite!\n")
                Util.aguarde(1000)
                retorne
            }

            inteiro preco = g_loja_preco[idx]
            se (g_ciclo_dia_noite == "Noite" e g_loja_categoria[idx] == CAT_CONSUMIVEL) { preco = preco * 125 / 100 }
            se (g_ciclo_dia_noite == "Noite" e idx >= 11) { preco = preco * 80 / 100 }
            preco = preco - (preco * g_desconto / 100)

            se (g_ouro >= preco)
            {
                g_ouro = g_ouro - preco
                g_reputacao = g_reputacao + preco
                se (g_reputacao >= 500) { g_desconto = g_desconto + 5 g_reputacao = 0 }
                se (g_desconto > 20) { g_desconto = 20 }

                adicionar_item(g_loja_nome[idx], g_loja_desc[idx], "Consumivel", g_loja_raridade[idx], g_loja_categoria[idx], ELEM_NEUTRO, 1, 0.5, g_loja_preco[idx], g_loja_nivel_req[idx], verdadeiro, verdadeiro, falso, verdadeiro, falso, 0, 0, 0, 0, 0, 0, g_loja_efeito[idx])
                escreva("Compra realizada!\n")
            }
            senao
            {
                escreva("Ouro insuficiente!\n")
            }
            Util.aguarde(1000)
        }
    }

    funcao loja_upgrades()
    {
        limpa()
        escreva("================================\n")
        escreva("        FERREIRO\n")
        escreva("================================\n")
        escreva("Arma: ", g_arma_nome, " (", g_arma_durabilidade, "/", g_arma_durabilidade_max, ")\n")
        escreva("Refino: +", g_arma_nivel_refino, "\n")
        escreva("================================\n")
        escreva("[1] Reparar Arma (", g_arma_durabilidade_max - g_arma_durabilidade, "g)\n")
        escreva("[2] Refinar Arma +", g_arma_nivel_refino + 1, "\n")
        escreva("[0] Voltar\n")
        escreva("Escolha: ")
        inteiro chsen
        leia(chsen)

        se (chsen == 1)
        {
            inteiro custo = (g_arma_durabilidade_max - g_arma_durabilidade) / 2
            se (g_ouro >= custo)
            {
                g_ouro = g_ouro - custo
                g_arma_durabilidade = g_arma_durabilidade_max
                escreva("Arma reparada!\n")
            }
            senao { escreva("Ouro insuficiente!\n") }
            Util.aguarde(1000)
        }
        senao se (chsen == 2)
        {
            inteiro custo = 0
            se (g_arma_nivel_refino == 0) { custo = 100 }
            senao se (g_arma_nivel_refino == 1) { custo = 250 }
            senao se (g_arma_nivel_refino == 2) { custo = 500 }
            senao se (g_arma_nivel_refino == 3) { custo = 1000 }
            senao se (g_arma_nivel_refino == 4) { custo = 2500 }
            senao { escreva("Refino maximo atingido!\n") Util.aguarde(1000) retorne }

            se (g_nivel < g_arma_nivel_refino + 1) { escreva("Nivel insuficiente!\n") Util.aguarde(1000) retorne }

            se (g_ouro >= custo)
            {
                g_ouro = g_ouro - custo
                g_arma_nivel_refino = g_arma_nivel_refino + 1
                escreva("Arma refinada +", g_arma_nivel_refino, "!\n")
            }
            senao { escreva("Ouro insuficiente!\n") }
            Util.aguarde(1000)
        }
    }

    funcao menu_venda()
    {
        limpa()
        escreva("================================\n")
        escreva("         VENDER ITENS\n")
        escreva("================================\n")

        inteiro i
        para (i = 0; i < g_inv_slots_usados; i = i + 1)
        {
            se (g_inv_quest[i] == falso)
            {
                inteiro preco_venda = g_inv_valor[i]
                se (g_inv_raridade[i] == RAR_COMUM) { preco_venda = preco_venda * 30 / 100 }
                senao se (g_inv_raridade[i] >= RAR_RARO) { preco_venda = preco_venda * 50 / 100 }
                escreva("[", i + 1, "] ", g_inv_nome[i], " - ", preco_venda, "g\n")
            }
        }
        escreva("[0] Voltar\n")
        escreva("Escolha: ")
        inteiro chhhsen
        leia(chhhsen)

        se (chhhsen > 0 e chhhsen <= g_inv_slots_usados)
        {
            vender_item(chhhsen - 1)
        }
    }

    // ==========================================
    // SISTEMA DE QUESTS
    // ==========================================
    funcao atualizar_quests_combate()
    {
        inteiro i
        para (i = 0; i < g_quest_count; i = i + 1)
        {
            se (g_quest_ativa[i] e g_quest_completa[i] == falso)
            {
                g_quest_progresso[i] = g_quest_progresso[i] + 1
                se (g_quest_progresso[i] >= g_quest_objetivo[i])
                {
                    g_quest_completa[i] = verdadeiro
                    g_xp = g_xp + g_quest_xp_recompensa[i]
                    g_ouro = g_ouro + g_quest_ouro_recompensa[i]
                    escreva("[Quest Completa] ", g_quest_nome[i], "!\n")
                    escreva("Recompensa: ", g_quest_xp_recompensa[i], " XP, ", g_quest_ouro_recompensa[i], "g\n")
                }
            }
        }
    }

    funcao menu_quests()
    {
        limpa()
        escreva("================================\n")
        escreva("           QUESTS\n")
        escreva("================================\n")

        inteiro i
        para (i = 0; i < g_quest_count; i = i + 1)
        {
            se (g_quest_ativa[i])
            {
                cadeia status = "Ativa"
                se (g_quest_completa[i]) { status = "Completa" }
                escreva("[", i + 1, "] ", g_quest_nome[i], " [", status, "]\n")
                escreva("    ", g_quest_desc[i], "\n")
                escreva("    Progresso: ", g_quest_progresso[i], "/", g_quest_objetivo[i], "\n")
            }
        }
        escreva("\n[0] Voltar\n")
        escreva("Escolha: ")
        inteiro cahsen
        leia(cahsen)
        Util.aguarde(500)
    }

    // ==========================================
    // SISTEMA DE MAPA E EXPLORACAO
    // ==========================================
    funcao gerar_mapa()
    {
        g_mapa_parar_geracao = falso

        // Limpar matriz
        inteiro i, j
        para (i = 0; i < g_mapa_tamanho_x; i = i + 1)
        {
            para (j = 0; j < g_mapa_tamanho_y; j = j + 1)
            {
                g_mapa_matriz[i][j] = "Nada"
            }
        }

        // Start aleatorio
        inteiro startX = Util.sorteia(1, g_mapa_tamanho_x - 2)
        g_mapa_player_x = startX
        g_mapa_player_y = 0
        g_mapa_matriz[startX][0] = "O"

        // Gerar caminhos
        enquanto (g_mapa_parar_geracao == falso)
        {
            calcular_mapa()
        }

        // Colocar elementos especiais
        colocar_elementos_mapa()

        g_mapa_gerado = verdadeiro
    }

    funcao calcular_mapa()
    {
        inteiro xPos = 0, yPos = 0
        inteiro positions[4]

        // Encontrar posicao atual
        inteiro i, j
        para (i = 0; i < g_mapa_tamanho_x; i = i + 1)
        {
            para (j = 0; j < g_mapa_tamanho_y; j = j + 1)
            {
                se (g_mapa_matriz[i][j] == "O")
                {
                    xPos = i
                    yPos = j
                }
            }
        }

        // Verificar saidas
        se (yPos - 1 >= 0 e g_mapa_matriz[xPos][yPos - 1] == "Nada") { positions[0] = 0 } senao { positions[0] = 1 }
        se (yPos + 1 < g_mapa_tamanho_y e g_mapa_matriz[xPos][yPos + 1] == "Nada") { positions[1] = 0 } senao { positions[1] = 1 }
        se (xPos + 1 < g_mapa_tamanho_x e g_mapa_matriz[xPos + 1][yPos] == "Nada") { positions[2] = 0 } senao { positions[2] = 1 }
        se (xPos - 1 >= 0 e g_mapa_matriz[xPos - 1][yPos] == "Nada") { positions[3] = 0 } senao { positions[3] = 1 }

        logico temSaida = falso
        para (i = 0; i < 4; i = i + 1)
        {
            se (positions[i] == 0) { temSaida = verdadeiro }
        }

        se (temSaida == falso)
        {
            g_mapa_parar_geracao = verdadeiro
            retorne
        }

        logico ladoEscolhido = falso
        enquanto (ladoEscolhido == falso)
        {
            inteiro idLado = Util.sorteia(1, 4)
            se (idLado == 1 e positions[0] == 0)
            {
                g_mapa_matriz[xPos][yPos] = "Caminho"
                g_mapa_matriz[xPos][yPos - 1] = "O"
                ladoEscolhido = verdadeiro
            }
            senao se (idLado == 2 e positions[1] == 0)
            {
                g_mapa_matriz[xPos][yPos] = "Caminho"
                g_mapa_matriz[xPos][yPos + 1] = "O"
                ladoEscolhido = verdadeiro
            }
            senao se (idLado == 3 e positions[2] == 0)
            {
                g_mapa_matriz[xPos][yPos] = "Caminho"
                g_mapa_matriz[xPos + 1][yPos] = "O"
                ladoEscolhido = verdadeiro
            }
            senao se (idLado == 4 e positions[3] == 0)
            {
                g_mapa_matriz[xPos][yPos] = "Caminho"
                g_mapa_matriz[xPos - 1][yPos] = "O"
                ladoEscolhido = verdadeiro
            }
        }
    }

    funcao colocar_elementos_mapa()
    {
        inteiro i, j
        para (i = 0; i < g_mapa_tamanho_x; i = i + 1)
        {
            para (j = 0; j < g_mapa_tamanho_y; j = j + 1)
            {
                se (g_mapa_matriz[i][j] == "Caminho")
                {
                    // Chance de inimigo
                    se (Util.sorteia(1, 100) <= 15)
                    {
                        g_mapa_matriz[i][j] = g_mapa_char_inimigo
                    }
                    // Chance de bau
                    senao se (Util.sorteia(1, 100) <= 5)
                    {
                        g_mapa_matriz[i][j] = g_mapa_char_bau
                    }
                    // Chance de loja
                    senao se (Util.sorteia(1, 100) <= 3)
                    {
                        g_mapa_matriz[i][j] = g_mapa_char_loja
                    }
                    // Chance de arvore
                    senao se (Util.sorteia(1, 100) <= 10)
                    {
                        g_mapa_matriz[i][j] = g_mapa_char_arvore
                    }
                }
            }
        }
        // Colocar saida no final
        para (i = g_mapa_tamanho_x - 1; i >= 0; i = i - 1)
        {
            para (j = g_mapa_tamanho_y - 1; j >= 0; j = j - 1)
            {
                se (g_mapa_matriz[i][j] == "Caminho")
                {
                    g_mapa_matriz[i][j] = g_mapa_char_saida
                    retorne
                }
            }
        }
    }

    funcao desenhar_mapa()
    {
        limpa()
        inteiro i, j
        cadeia charTeto = "=", charParede = "|"
        inteiro numBorda = g_mapa_tamanho_y + 2

        // Borda superior
        para (i = 1; i <= numBorda; i = i + 1) { escreva(charTeto) }
        escreva("\n")

        // Desenhar mapa
        para (i = 0; i < g_mapa_tamanho_x; i = i + 1)
        {
            escreva(charParede)
            para (j = 0; j < g_mapa_tamanho_y; j = j + 1)
            {
                se (i == g_mapa_player_x e j == g_mapa_player_y)
                {
                    escreva(g_mapa_char_player)
                }
                senao se (g_mapa_matriz[i][j] == "Caminho")
                {
                    escreva(" ")
                }
                senao se (g_mapa_matriz[i][j] == "Nada")
                {
                    escreva(".")
                }
                senao
                {
                    escreva(g_mapa_matriz[i][j])
                }
            }
            escreva(charParede, "\n")
        }

        // Borda inferior
        para (i = 1; i <= numBorda; i = i + 1) { escreva(charTeto) }
        escreva("\n")
    }

    funcao mover_jogador(cadeia direcao)
    {
        inteiro novoX = g_mapa_player_x
        inteiro novoY = g_mapa_player_y

        se (direcao == "w") { novoX = novoX - 1 }
        senao se (direcao == "s") { novoX = novoX + 1 }
        senao se (direcao == "a") { novoY = novoY - 1 }
        senao se (direcao == "d") { novoY = novoY + 1 }

        // Verificar limites
        se (novoX < 0 ou novoX >= g_mapa_tamanho_x) { retorne }
        se (novoY < 0 ou novoY >= g_mapa_tamanho_y) { retorne }

        cadeia destino = g_mapa_matriz[novoX][novoY]

        // Verificar se pode mover
        se (destino == "Nada") { retorne }

        // Verificar o que ha no destino
        se (destino == g_mapa_char_inimigo)
        {
            // Combate!
            inteiro nivel_inimigo = g_nivel + Util.sorteia(-1, 2)
            se (nivel_inimigo < 1) { nivel_inimigo = 1 }
            logico elite = (Util.sorteia(1, 100) <= 20)
            gerar_combate(nivel_inimigo, elite, falso)
            g_mapa_matriz[novoX][novoY] = "Caminho"
        }
        senao se (destino == g_mapa_char_bau)
        {
            // Abrir bau
            abrir_bau()
            g_mapa_matriz[novoX][novoY] = "Caminho"
        }
        senao se (destino == g_mapa_char_loja)
        {
            // Loja
            loja()
            g_mapa_matriz[novoX][novoY] = "Caminho"
        }
        senao se (destino == g_mapa_char_saida)
        {
            // Saida - novo mapa
            escreva("Voce encontrou a saida!\n")
            escreva("Gerando novo mapa...\n")
            Util.aguarde(2000)
            gerar_mapa()
            g_mapa_player_x = Util.sorteia(1, g_mapa_tamanho_x - 2)
            g_mapa_player_y = 0
            g_mapa_matriz[g_mapa_player_x][g_mapa_player_y] = "Caminho"
        }
        senao se (destino == g_mapa_char_arvore)
        {
            // Arvore - chance de loot
            se (Util.sorteia(1, 100) <= 30)
            {
                escreva("Voce encontrou recursos na arvore!\n")
                g_ouro = g_ouro + Util.sorteia(5, 15)
            }
            g_mapa_matriz[novoX][novoY] = "Caminho"
        }
        senao
        {
            // Movimento normal - chance de evento
            se (Util.sorteia(1, 100) <= 25)
            {
                evento_aleatorio()
            }
        }

        // Mover jogador
        g_mapa_player_x = novoX
        g_mapa_player_y = novoY

        // Aumentar contador de acoes
        g_acoes_totais = g_acoes_totais + 1
        verificar_ciclo_tempo()
        atualizar_fome()
    }

    funcao abrir_bau()
    {
        limpa()
        escreva("================================\n")
        escreva("         BAU ENCONTRADO!\n")
        escreva("================================\n")

        inteiro roll = Util.sorteia(1, 100)
        se (roll <= 10)
        {
            // Item raro
            inteiro ouro = Util.sorteia(50, 150)
            g_ouro = g_ouro + ouro
            escreva("Ouro: +", ouro, "g\n")
            gerar_loot_bau()
        }
        senao se (roll <= 50)
        {
            // Ouro
            inteiro ouro = Util.sorteia(20, 80)
            g_ouro = g_ouro + ouro
            escreva("Ouro: +", ouro, "g\n")
        }
        senao
        {
            // Pocao
            adicionar_item("Pocao de Vida P", "Recupera 30 HP", "Consumivel", RAR_COMUM, CAT_CONSUMIVEL, ELEM_NEUTRO, 1, 0.5, 25, 1, verdadeiro, verdadeiro, falso, verdadeiro, falso, 0, 0, 0, 0, 0, 0, 2)
            escreva("Pocao de Vida P obtida!\n")
        }
        escreva("================================\n")
        Util.aguarde(1500)
    }

    funcao gerar_loot_bau()
    {
        cadeia prefixos[6]
        prefixos[0] = "Antiga"
        prefixos[1] = "Encantada"
        prefixos[2] = "Reluzente"
        prefixos[3] = "Sombria"
        prefixos[4] = "Sagrada"
        prefixos[5] = "Amaldicoada"

        cadeia tipos[4]
        tipos[0] = "Espada"
        tipos[1] = "Armadura"
        tipos[2] = "Amuleto"
        tipos[3] = "Anel"

        inteiro p = Util.sorteia(0, 5)
        inteiro t = Util.sorteia(0, 3)
        cadeia nome = prefixos[p] + " " + tipos[t]
        inteiro raridade = Util.sorteia(2, 4)
        inteiro bonus = raridade * 5

        se (t == 0)
        {
            adicionar_item(nome, "Arma " + nome_raridade(raridade), "Equipamento", raridade, 1, ELEM_NEUTRO, 1, 5.0, bonus * 10, g_nivel, falso, falso, verdadeiro, verdadeiro, falso, bonus, 0, bonus / 2, 0, 0, 0, 0)
        }
        senao se (t == 1)
        {
            adicionar_item(nome, "Armadura " + nome_raridade(raridade), "Equipamento", raridade, 2, ELEM_NEUTRO, 1, 8.0, bonus * 10, g_nivel, falso, falso, verdadeiro, verdadeiro, falso, 0, bonus, 0, 0, 0, bonus * 10, 0)
        }
        senao
        {
            adicionar_item(nome, "Acessorio " + nome_raridade(raridade), "Equipamento", raridade, 3, ELEM_NEUTRO, 1, 1.0, bonus * 10, g_nivel, falso, falso, verdadeiro, verdadeiro, falso, bonus / 2, bonus / 2, bonus, bonus / 2, bonus * 2, bonus * 5, 0)
        }
        escreva(nome, " obtido!\n")
    }

    funcao evento_aleatorio()
    {
        inteiro roll = Util.sorteia(1, 100)
        inteiro evento_idx = -1

        se (roll <= 45)
        {
            // Combate
            escreva("\n[Evento] ", g_evento_nome[0], "\n")
            escreva(g_evento_desc[0], "\n")
            Util.aguarde(1000)
            inteiro nivel_inimigo = g_nivel + Util.sorteia(-1, 1)
            se (nivel_inimigo < 1) { nivel_inimigo = 1 }
            gerar_combate(nivel_inimigo, falso, falso)
        }
        senao se (roll <= 65)
        {
            // Loot
            limpa()
            escreva("[Evento] ", g_evento_nome[1], "\n")
            escreva(g_evento_desc[1], "\n")
            g_ouro = g_ouro + Util.sorteia(10, 30)
            escreva("Ouro: +", Util.sorteia(10, 30), "g\n")
            Util.aguarde(1500)
        }
        senao se (roll <= 75)
        {
            // Mercador
            limpa()
            escreva("[Evento] ", g_evento_nome[2], "\n")
            escreva(g_evento_desc[2], "\n")
            loja()
        }
        senao se (roll <= 85)
        {
            // Armadilha
            limpa()
            escreva("[Evento] ", g_evento_nome[3], "\n")
            escreva(g_evento_desc[3], "\n")
            dano = Util.sorteia(5, 15) + g_nivel * 2
            g_hp_atual = g_hp_atual - dano
            se (g_hp_atual < 1) { g_hp_atual = 1 }
            escreva("Dano: -", dano, " HP\n")
            Util.aguarde(1500)
        }
        senao se (roll <= 95)
        {
            // Quest
            limpa()
            escreva("[Evento] ", g_evento_nome[4], "\n")
            escreva(g_evento_desc[4], "\n")
            ativar_quest_aleatoria()
            Util.aguarde(1500)
        }
        senao
        {
            // Fonte misteriosa
            limpa()
            escreva("[Evento] ", g_evento_nome[5], "\n")
            escreva(g_evento_desc[5], "\n")
            g_hp_atual = g_hp_max
            g_mana_atual = g_mana_max
            escreva("HP e Mana totalmente restaurados!\n")
            Util.aguarde(1500)
        }
    }

    funcao ativar_quest_aleatoria()
    {
        inteiro i
        para (i = 0; i < g_quest_count; i = i + 1)
        {
            se (g_quest_ativa[i] == falso)
            {
                g_quest_ativa[i] = verdadeiro
                g_quest_progresso[i] = 0
                escreva("[Nova Quest] ", g_quest_nome[i], "\n")
                retorne
            }
        }
        escreva("Nenhuma quest disponivel.\n")
    }

    funcao verificar_ciclo_tempo()
    {
        se (g_acoes_totais % g_acoes_para_mudar_tempo == 0)
        {
            se (g_ciclo_dia_noite == "Dia")
            {
                g_ciclo_dia_noite = "Noite"
                escreva("\n[A noite caiUtil... Inimigos mais fortes!]\n")
            }
            senao
            {
                g_ciclo_dia_noite = "Dia"
                escreva("\n[O sol nasce! Um novo dia comeca.]\n")
            }
            Util.aguarde(1000)
        }
    }

    funcao atualizar_fome()
    {
        se (g_em_combate)
        {
            g_fome = g_fome - 4
        }
        senao
        {
            g_fome = g_fome - 2
        }

        se (g_fome <= 0)
        {
            g_fome = 0
            g_exausto = verdadeiro
        }
        senao se (g_fome < 10)
        {
            g_exausto = verdadeiro
        }
        senao se (g_fome < 25)
        {
            g_exausto = falso
        }
        senao
        {
            g_exausto = falso
        }
    }

    // ==========================================
    // SISTEMA DE SAVE/LOAD
    // ==========================================
    funcao salvar_jogo()
    {
        limpa()
        escreva("================================\n")
        escreva("         SALVAR JOGO\n")
        escreva("================================\n")
        escreva("Anote este codigo para continuar depois:\n\n")

        // Gerar save code simples
        cadeia codigo = ""
        codigo = codigo + g_nome_jogador + "|"
        codigo = codigo + g_classe_jogador + "|"
        codigo = codigo + g_nivel + "|"
        codigo = codigo + g_xp + "|"
        codigo = codigo + g_ouro + "|"
        codigo = codigo + g_forca + "|"
        codigo = codigo + g_defesa + "|"
        codigo = codigo + g_inteligencia + "|"
        codigo = codigo + g_agilidade + "|"
        codigo = codigo + g_vitalidade + "|"
        codigo = codigo + g_arma_nivel_refino + "|"
        codigo = codigo + g_arma_durabilidade + "|"
        codigo = codigo + g_fome

        escreva("SAVE CODE: ", codigo, "\n\n")
        escreva("Anote e use ao iniciar o jogo!\n")
        escreva("[Enter] para continuar...")
        cadeia temp
        leia(temp)
    }

    funcao logico carregar_jogo()
    {
        limpa()
        escreva("================================\n")
        escreva("         CARREGAR JOGO\n")
        escreva("================================\n")
        escreva("Digite o Save Code:\n")
        cadeia codigo
        leia(codigo)

        // Parse simples do codigo (formato basico)
        // Para um sistema completo, seria necessario um parser mais robusto
        se (codigo != "")
        {
            escreva("Codigo recebido!\n")
            escreva("Jogo carregado com sucesso!\n")
            Util.aguarde(1000)
            retorne verdadeiro
        }
        retorne falso
    }

    // ==========================================
    // HUD E INTERFACE
    // ==========================================
    funcao mostrar_hud_combate(inteiro inimigo_idx)
    {
        limpa()
        escreva("================================\n")
        escreva("  COMBATE - Turno: ", g_combate_turno, " [", g_ciclo_dia_noite, "]\n")
        escreva("================================\n")

        // HUD Inimigo
        escreva("INIMIGO: ", g_inim_nome[inimigo_idx], "\n")
        escreva("HP: ", g_inim_hp_atual[inimigo_idx], "/", g_inim_hp_max[inimigo_idx], "\n")

        // Barra de stagger
        real stagger_pct = (g_inim_stagger_atual[inimigo_idx] + 0.0) / g_inim_stagger_max[inimigo_idx] * 100
        escreva("Stagger: ", Matematica.arredondar(stagger_pct, 0), "%\n") 

        se (g_inim_stunned[inimigo_idx]) { escreva("[ATORDOADO]\n") }
        escreva("--------------------------------\n")

        // HUD Jogador
        escreva("JOGADOR: ", g_nome_jogador, " (", nome_classe(g_classe_jogador), ")\n")
        escreva("HP: ", g_hp_atual, "/", g_hp_max, "\n")
        escreva("MP: ", g_mana_atual, "/", g_mana_max, "\n")
        escreva("Stamina: ", g_stamina, "\n")
        escreva("Fome: ", g_fome, "\n")
        escreva("Ouro: ", g_ouro, "g\n")
        escreva("Arma: ", g_arma_nome, " (", g_arma_durabilidade, "%)\n")

        // Buffs
        se (g_buff_count > 0)
        {
            escreva("BUFFS: ")
            inteiro i
            para (i = 0; i < g_buff_count; i = i + 1)
            {
                se (g_buff_ativo[i])
                {
                    escreva("[", g_buff_nome[i], ":", g_buff_duracao[i], "T] ")
                }
            }
            escreva("\n")
        }

        // Debuffs
        se (g_debuff_count > 0)
        {
            escreva("DEBUFFS: ")
            inteiro i
            para (i = 0; i < g_debuff_count; i = i + 1)
            {
                se (g_debuff_ativo[i])
                {
                    escreva("[", g_debuff_nome[i], ":", g_debuff_duracao[i], "T] ")
                }
            }
            escreva("\n")
        }

        se (g_exausto) { escreva("[EXAUSTO] Atributos reduzidos!\n") }
        escreva("================================\n")
    }

    funcao mostrar_hud_exploracao()
    {
        limpa()
        escreva("================================\n")
        escreva("  ", NOME_JOGO, "\n")
        escreva("================================\n")
        escreva("Jogador: ", g_nome_jogador, "\n")
        escreva("Classe: ", nome_classe(g_classe_jogador), " | Nivel: ", g_nivel, "\n")
        escreva("HP: ", g_hp_atual, "/", g_hp_max, " | MP: ", g_mana_atual, "/", g_mana_max, "\n")
        escreva("Ouro: ", g_ouro, "g | Fome: ", g_fome, "\n")
        escreva("Tempo: ", g_ciclo_dia_noite, "\n")
        escreva("Regiao: ", g_mapa_regiao_atual, "\n")
        escreva("XP: ", g_xp, "/", g_xp_proximo, "\n")
        escreva("================================\n")
    }

    // ==========================================
    // MENU PRINCIPAL
    // ==========================================
    funcao menu_principal()
    {
        logico jogando = verdadeiro
        enquanto (jogando)
        {
            mostrar_hud_exploracao()
            desenhar_mapa()

            escreva("\n[1] Explorar\n")
            escreva("[2] Inventario\n")
            escreva("[3] Status\n")
            escreva("[4] Quests\n")
            escreva("[5] Loja\n")
            escreva("[6] Salvar\n")
            escreva("[7] Sair\n")
            escreva("Escolha: ")
            inteiro choseeen
            leia(choseeen)

            se (choseeen == 1)
            {
                menu_exploracao()
            }
            senao se (choseeen == 2)
            {
                mostrar_inventario()
            }
            senao se (choseeen == 3)
            {
                mostrar_status()
            }
            senao se (choseeen == 4)
            {
                menu_quests()
            }
            senao se (choseeen == 5)
            {
                loja()
            }
            senao se (choseeen == 6)
            {
                salvar_jogo()
            }
            senao se (choseeen == 7)
            {
                escreva("Deseja salvar antes de sair? [1] Sim [2] Nao: ")
                inteiro save_choice
                leia(save_choice)
                se (save_choice == 1) { salvar_jogo() }
                jogando = falso
            }
        }
    }

    funcao menu_exploracao()
    {
        limpa()
        desenhar_mapa()
        escreva("\nPara onde ir?\n")
        escreva("[W] Cima  [S] Baixo\n")
        escreva("[A] Esquerda  [D] Direita\n")
        escreva("[0] Voltar\n")
        escreva("Escolha: ")
        cadeia mov
        leia(mov)

        se (mov == "w" ou mov == "s" ou mov == "a" ou mov == "d")
        {
            mover_jogador(mov)
        }
    }

    funcao mostrar_status()
    {
        limpa()
        escreva("================================\n")
        escreva("         STATUS\n")
        escreva("================================\n")
        escreva("Nome: ", g_nome_jogador, "\n")
        escreva("Classe: ", nome_classe(g_classe_jogador), "\n")
        escreva("Nivel: ", g_nivel, "\n")
        escreva("XP: ", g_xp, "/", g_xp_proximo, "\n")
        escreva("--------------------------------\n")
        escreva("FOR: ", g_forca, "\n")
        escreva("DEF: ", g_defesa, "\n")
        escreva("INT: ", g_inteligencia, "\n")
        escreva("AGI: ", g_agilidade, "\n")
        escreva("VIT: ", g_vitalidade, "\n")
        escreva("PREC: ", g_precisao, "%\n")
        escreva("CRT: ", calcular_critico_total(), "%\n")
        escreva("ESQ: ", calcular_esquiva_total(), "%\n")
        escreva("--------------------------------\n")
        escreva("Ataque Total: ", calcular_ataque_total(), "\n")
        escreva("Defesa Total: ", calcular_defesa_total(), "\n")
        escreva("HP Max: ", g_hp_max, "\n")
        escreva("Mana Max: ", g_mana_max, "\n")
        escreva("--------------------------------\n")
        escreva("Arma: ", g_arma_nome, " +", g_arma_nivel_refino, "\n")
        escreva("Durabilidade: ", g_arma_durabilidade, "/", g_arma_durabilidade_max, "\n")
        escreva("Armadura: ", g_armadura_nome, "\n")
        escreva("--------------------------------\n")
        escreva("Combates Vencidos: ", g_combates_vencidos, "\n")
        escreva("Bosses Derrotados: ", g_bosses_derrotados, "\n")
        escreva("================================\n")
        escreva("[Enter] para continuar...")
        cadeia temp
        leia(temp)
    }

    // ==========================================
    // SELECAO DE CLASSE
    // ==========================================
    funcao selecionar_classe()
    {
        limpa()
        escreva("================================\n")
        escreva("       ESCOLHA SUA CLASSE\n")
        escreva("================================\n\n")

        escreva("[1] Guerreiro - Pressao fisica + Resistencia\n")
        escreva("    Skill inicial: Golpe Pesado (150% dano)\n\n")

        escreva("[2] Mago - Burst magico + Controle\n")
        escreva("    Skill inicial: Dardo Mistico (130% magico)\n\n")

        escreva("[3] Ladino - Critico + Evasao\n")
        escreva("    Skill inicial: Punhalada (80% + 50% crit)\n\n")

        escreva("[4] Paladino - Sustain + Protecao\n")
        escreva("    Skill inicial: Golpe de Luz (120% vs Trevas 2.5x)\n\n")

        escreva("[5] Arqueiro - Precisão + Controle\n")
        escreva("    Skill inicial: Tiro Rapido (2x 60% dano)\n\n")

        escreva("[6] Druida - Regeneracao + Transformacao\n")
        escreva("    Skill inicial: Chicote de Cipo (110% -10% DEF)\n\n")

        escreva("[7] Necromante - Drenagem + Debuffs\n")
        escreva("    Skill inicial: Toque Sombrio (90% -15% dano alvo)\n\n")

        escreva("[8] Monge - Combos + Ritmo\n")
        escreva("    Skill inicial: Palma de Ferro (120% ignora armadura)\n\n")

        escreva("Escolha: ")
        inteiro acshone
        leia(acshone)

        se (acshone >= 1 e acshone <= 8)
        {
            g_classe_jogador = acshone

            // Atributos iniciais por classe
            se (acshone == CLS_GUERREIRO)
            {
                g_forca = 8 g_defesa = 7 g_inteligencia = 3 g_agilidade = 4 g_vitalidade = 6
                g_arma_dano = 15 g_arma_nome = "Espada Longa"
            }
            senao se (acshone == CLS_MAGO)
            {
                g_forca = 3 g_defesa = 4 g_inteligencia = 9 g_agilidade = 4 g_vitalidade = 5
                g_arma_dano = 10 g_arma_nome = "Cajado Arcano"
            }
            senao se (acshone == CLS_LADINO)
            {
                g_forca = 5 g_defesa = 4 g_inteligencia = 4 g_agilidade = 9 g_vitalidade = 4
                g_arma_dano = 12 g_arma_nome = "Adaga Dupla"
                g_critico = 10 g_esquiva = 8
            }
            senao se (acshone == CLS_PALADINO)
            {
                g_forca = 6 g_defesa = 7 g_inteligencia = 5 g_agilidade = 3 g_vitalidade = 7
                g_arma_dano = 12 g_arma_nome = "Martelo Sagrado"
            }
            senao se (acshone == CLS_ARQUEIRO)
            {
                g_forca = 5 g_defesa = 4 g_inteligencia = 4 g_agilidade = 8 g_vitalidade = 4
                g_arma_dano = 13 g_arma_nome = "Arco Curto"
                g_precisao = 95 g_critico = 8
            }
            senao se (acshone == CLS_DRUIDA)
            {
                g_forca = 5 g_defesa = 6 g_inteligencia = 6 g_agilidade = 4 g_vitalidade = 7
                g_arma_dano = 10 g_arma_nome = "Cajado Natural"
            }
            senao se (acshone == CLS_NECROMANTE)
            {
                g_forca = 4 g_defesa = 4 g_inteligencia = 8 g_agilidade = 4 g_vitalidade = 5
                g_arma_dano = 10 g_arma_nome = "Cajado Sombrio"
            }
            senao se (acshone == CLS_MONGE)
            {
                g_forca = 7 g_defesa = 5 g_inteligencia = 4 g_agilidade = 7 g_vitalidade = 5
                g_arma_dano = 11 g_arma_nome = "Luvas de Combate"
            }

            // Calcular stats derivados
            g_hp_max = calcular_hp_max()
            g_hp_atual = g_hp_max
            g_mana_max = calcular_mana_max()
            g_mana_atual = g_mana_max
        }
        senao
        {
            g_classe_jogador = CLS_GUERREIRO
            g_forca = 8 g_defesa = 7 g_inteligencia = 3 g_agilidade = 4 g_vitalidade = 6
            g_arma_dano = 15 g_arma_nome = "Espada Longa"
            g_hp_max = calcular_hp_max()
            g_hp_atual = g_hp_max
            g_mana_max = calcular_mana_max()
            g_mana_atual = g_mana_max
        }
    }

    // ==========================================
    // INICIO
    // ==========================================
    funcao inicio()
    {
        // Inicializar sistemas
        inicializar_jogo()

        // Tela inicial
        limpa()
        escreva(NOME_JOGO, "\n")
        escreva(VERSAO, "\n\n")
        escreva("[1] Novo Jogo\n")
        escreva("[2] Carregar Jogo\n")
        escreva("Escolha: ")
        inteiro bchoisce
        leia(bchoisce)

        se (bchoisce == 2)
        {
            carregar_jogo()
        }

        // Nome do jogador
        limpa()
        escreva("Digite seu nome: ")
        leia(g_nome_jogador)

        // Selecionar classe
        selecionar_classe()

        // Itens iniciais
        adicionar_item("Pocao de Vida P", "Recupera 30 HP", "Consumivel", RAR_COMUM, CAT_CONSUMIVEL, ELEM_NEUTRO, 3, 0.5, 25, 1, verdadeiro, verdadeiro, falso, verdadeiro, falso, 0, 0, 0, 0, 0, 0, 2)
        adicionar_item("Pocao de Mana P", "Recupera 30 MP", "Consumivel", RAR_COMUM, CAT_CONSUMIVEL, ELEM_NEUTRO, 2, 0.5, 25, 1, verdadeiro, verdadeiro, falso, verdadeiro, falso, 0, 0, 0, 0, 0, 0, 3)
        adicionar_item("Pao Velho", "Recupera 15 Fome", "Consumivel", RAR_COMUM, CAT_CONSUMIVEL, ELEM_NEUTRO, 5, 0.3, 10, 1, verdadeiro, verdadeiro, falso, verdadeiro, falso, 0, 0, 0, 0, 0, 0, 1)

        // Gerar primeiro mapa
        limpa()
        escreva("Gerando mundo...\n")
        Util.aguarde(1500)
        gerar_mapa()

        // Combate tutorial
        limpa()
        escreva("================================\n")
        escreva("         TUTORIAL\n")
        escreva("================================\n")
        escreva("Um inimigo aparece! Prepare-se!\n")
        escreva("Use [1] para atacar basicamente.\n")
        escreva("Use [2] para usar sua habilidade.\n")
        escreva("Use [3] para usar itens.\n")
        escreva("================================\n")
        Util.aguarde(3000)

        gerar_combate(1, falso, falso)

        // Iniciar exploracao
        menu_principal()
    }
}
